@{
    ViewData["Title"] = "Шиномонтаж у Бориса";
    Layout = null;
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Шиномонтаж у Бориса — Система управления шиномонтажем</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;900&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
            background: #0a0a0f;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
        }
        .bg-glow {
            position: fixed;
            inset: 0;
            background: radial-gradient(ellipse 600px 400px at 50% 40%, rgba(99,102,241,0.12), transparent 70%);
            pointer-events: none;
        }
        .container {
            position: relative;
            text-align: center;
            z-index: 1;
        }
        .logo-icon {
            font-size: 56px;
            margin-bottom: 8px;
            display: block;
        }
        h1 {
            font-size: 32px;
            font-weight: 900;
            color: #fff;
            letter-spacing: -0.5px;
            margin-bottom: 4px;
        }
        .subtitle {
            color: #64748b;
            font-size: 15px;
            font-weight: 400;
            margin-bottom: 48px;
        }
        .buttons {
            display: flex;
            gap: 40px;
            justify-content: center;
            flex-wrap: wrap;
        }
        .btn-circle {
            width: 200px;
            height: 200px;
            border-radius: 50%;
            border: 2px solid rgba(255,255,255,0.08);
            background: linear-gradient(145deg, rgba(255,255,255,0.04), rgba(255,255,255,0.01));
            backdrop-filter: blur(4px);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            text-decoration: none;
            color: #fff;
            transition: all 0.3s ease;
            cursor: pointer;
            gap: 8px;
            position: relative;
        }
        .btn-circle:hover {
            transform: scale(1.05);
            border-color: rgba(255,255,255,0.2);
            box-shadow: 0 0 40px rgba(99,102,241,0.15);
        }
        .btn-circle svg {
            width: 48px;
            height: 48px;
            opacity: 0.8;
        }
        .btn-circle .label {
            font-size: 14px;
            font-weight: 600;
            letter-spacing: 0.5px;
            color: rgba(255,255,255,0.7);
        }
        .btn-circle .sub {
            font-size: 11px;
            color: rgba(255,255,255,0.35);
        }
        .btn-client:hover {
            border-color: #22c55e;
            box-shadow: 0 0 40px rgba(34,197,94,0.15);
        }
        .btn-client svg { color: #22c55e; }
        .btn-master:hover {
            border-color: #6366f1;
            box-shadow: 0 0 40px rgba(99,102,241,0.15);
        }
        .btn-master svg { color: #6366f1; }
        .btn-admin:hover {
            border-color: #f59e0b;
            box-shadow: 0 0 40px rgba(245,158,11,0.15);
        }
        .btn-admin svg { color: #f59e0b; }
        footer {
            position: fixed;
            bottom: 24px;
            left: 0;
            right: 0;
            text-align: center;
            color: rgba(255,255,255,0.2);
            font-size: 12px;
            z-index: 1;
        }
        @@media (max-width: 700px) {
            .buttons { gap: 24px; }
            .btn-circle { width: 150px; height: 150px; }
            .btn-circle svg { width: 36px; height: 36px; }
            h1 { font-size: 24px; }
        }
    </style>
</head>
<body>
    <div class="bg-glow"></div>
    <div class="container">
        <svg class="logo-icon" viewBox="0 0 24 24" fill="none" stroke="#6366f1" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="width:56px;height:56px;display:inline-block;">
            <circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/>
        </svg>
        <h1>Шиномонтаж у Бориса</h1>
        <p class="subtitle">Система управления шиномонтажем</p>

        <div class="buttons">
            <a href="@Url.Action("Login", "Auth", new { area = "Worker" })" class="btn-circle btn-master">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/>
                </svg>
                <span class="label">Мастер</span>
                <span class="sub">Рабочее место</span>
            </a>

            <a href="@Url.Action("Login", "Auth", new { area = "Owner" })" class="btn-circle" style="border-color:rgba(168,85,247,0.3);" onmouseover="this.style.borderColor='rgba(168,85,247,0.6)';this.style.boxShadow='0 0 40px rgba(168,85,247,0.15)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.08)';this.style.boxShadow='none'">
                <svg viewBox="0 0 24 24" fill="none" stroke="#a855f7" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 22s-8-4-8-10V5l8-3 8 3v7c0 6-8 10-8 10z"/>
                </svg>
                <span class="label">Владелец</span>
                <span class="sub">Управление</span>
            </a>

            <a href="@Url.Content("~/Auth/Login")" class="btn-circle btn-admin">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                </svg>
                <span class="label">Админ</span>
                <span class="sub">Панель управления</span>
            </a>
        </div>
    </div>

    <footer>&copy; 2026 Шиномонтаж у Бориса — Система управления шиномонтажем</footer>
</body>
</html>
