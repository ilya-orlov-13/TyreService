@model TyreServiceApp.Models.Service

@{
    ViewData["Title"] = "Редактировать услугу";
}

<partial name="_FormStyles" />

<div class="container-fluid pt-2 pb-4">
    <div class="main-3d-wrapper" style="--mw: 600px">
        <div class="main-3d-inner">
            
            <!-- Заголовок -->
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h3 class="fw-bold m-0">
                    Редактировать услугу
                </h3>
            </div>

            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="alert-danger" role="alert"></div>
                <input type="hidden" asp-for="ServiceCode" />
                
                <div class="modern-form-group">
                    <label asp-for="ServiceName" class="modern-form-label">
                        <i class="bi bi-tools me-1"></i> Название услуги
                    </label>
                    <input asp-for="ServiceName" class="modern-form-input" placeholder="Например: Шиномонтаж" />
                    <span asp-validation-for="ServiceName" class="validation-error"></span>
                </div>
                
                <div class="modern-form-group">
                    <label asp-for="ServiceCost" class="modern-form-label">
                        <i class="bi bi-currency-exchange me-1"></i> Стоимость
                    </label>
                    <input asp-for="ServiceCost" class="modern-form-input" type="number" step="0.01" placeholder="0.00" />
                    <span asp-validation-for="ServiceCost" class="validation-error"></span>
                </div>
                
                <div class="modern-form-group">
                    <label asp-for="FixedDurationMin" class="modern-form-label">
                        <i class="bi bi-clock me-1"></i> Фиксированное время (мин)
                    </label>
                    <input asp-for="FixedDurationMin" class="modern-form-input" type="number" min="0" max="480" placeholder="Например: 30" />
                    <span asp-validation-for="FixedDurationMin" class="validation-error"></span>
                    <small class="text-muted">Если мастер выполнит быстрее — будет начислена премия</small>
                </div>

                <div class="modern-form-group">
                    <label class="modern-form-label d-flex align-items-center gap-2" style="cursor:pointer;">
                        <input asp-for="IsConsultation" type="checkbox" class="form-check-input m-0" />
                        <i class="bi bi-chat-dots me-1"></i> Консультация
                    </label>
                </div>
                
                <!-- Кнопки действий -->
                <div class="d-flex gap-2 mt-4 pt-2">
                    <button type="submit" class="btn btn-dark px-4">
                        <i class="bi bi-check-lg"></i> Сохранить изменения
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary px-4">
                        <i class="bi bi-x-lg"></i> Отмена
                    </a>
                </div>
            </form>

        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}