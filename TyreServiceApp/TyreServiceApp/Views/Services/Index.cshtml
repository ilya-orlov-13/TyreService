@model IEnumerable<TyreServiceApp.Models.Service>

@{
    ViewData["Title"] = "Услуги";
}

<partial name="_CardGridStyles" />
<style>
    .services-grid {
        min-width: 0;
        overflow: hidden;
    }
    .services-grid > * {
        min-width: 0;
    }

    .service-card-wrapper {
        cursor: pointer;
    }

    .add-card-wrapper {
        text-decoration: none;
        display: block;
    }

    .add-card {
        min-height: 100%;
        box-sizing: border-box;
    }

    .service-card {
        gap: 14px;
        cursor: pointer;
    }

    .card-top-row {
        display: flex;
        align-items: center;
        gap: 10px;
        width: 100%;
    }

    .service-code-left {
        flex-shrink: 0;
        font-size: 11px;
        font-weight: 700;
        color: #fff;
        background: #474747;
        padding: 3px 8px;
        border-radius: 6px;
        letter-spacing: 0.3px;
    }

    .service-name {
        flex: 1;
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        font-weight: 600;
        font-size: clamp(16px, 2vw, 22px);
        line-height: 1.15;
        color: #000000;
        text-align: left;
        user-select: none;
        min-width: 0;
    }

    .service-duration {
        flex-shrink: 0;
        font-size: 11px;
        font-weight: 600;
        color: #888;
        white-space: nowrap;
    }

    .card-bottom-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 8px;
        width: 100%;
    }

    .service-cost {
        font-weight: 700;
        font-size: 1.2rem;
        color: #000;
    }

    .action-btns {
        display: flex;
        gap: 6px;
        align-items: center;
    }

    .action-btn {
        background: none;
        border: 1.5px solid #ccc;
        border-radius: 10px;
        padding: 8px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s ease;
        color: #999;
        text-decoration: none;
    }

    .action-btn:hover {
        border-color: #000;
        background: #f5f5f5;
        color: #000;
    }

    .action-btn.danger:hover {
        border-color: #dc2626;
        background: #fef2f2;
        color: #dc2626;
    }

    .action-btn svg {
        width: 16px;
        height: 16px;
    }

    @@media (max-width: 768px) {
        .services-grid {
            grid-template-columns: 1fr;
            gap: 12px;
        }

        .service-card {
            padding: 16px;
        }

        .card-top-row {
            flex-wrap: wrap;
        }

        .service-name {
            font-size: clamp(16px, 3vw, 22px);
        }
    }

    @@media (max-width: 480px) {
        .service-card {
            padding: 14px;
        }
    }

    /* Delete modal styles */
    .modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0, 0, 0, 0.5);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 9999;
        opacity: 0;
        transition: opacity 0.3s ease;
    }

    .modal-overlay.modal-show {
        opacity: 1;
    }

    .modal-content {
        background: #fff;
        border-radius: 20px;
        padding: 32px;
        max-width: 420px;
        width: 90%;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
        position: relative;
        transform: translateY(10px);
        transition: transform 0.3s ease;
    }

    .modal-show .modal-content {
        transform: translateY(0);
    }

    .modal-header {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0;
        border: none;
        margin-bottom: 16px;
    }

    .modal-title {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        font-size: 20px;
        font-weight: 700;
        color: #111;
        margin: 0;
    }

    .modal-body {
        padding: 0;
        text-align: center;
        border: none;
    }

    .modal-text {
        font-size: 14px;
        color: #666;
        margin-bottom: 8px;
    }

    .modal-service-info {
        font-size: 16px;
        font-weight: 600;
        color: #111;
        margin-bottom: 4px;
        word-break: break-word;
    }

    .modal-hint {
        font-size: 12px;
        color: #999;
        margin: 0;
    }

    .modal-actions {
        display: flex;
        gap: 10px;
        margin-top: 24px;
    }

    .modal-btn {
        flex: 1;
        padding: 12px;
        border: none;
        border-radius: 12px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
    }

    .modal-btn-cancel {
        background: #f0f0f0;
        color: #333;
    }

    .modal-btn-cancel:hover {
        background: #e0e0e0;
    }

    .modal-btn-delete {
        background: #dc2626;
        color: white;
    }

    .modal-btn-delete:hover {
        background: #b91c1c;
    }

    .trash-icon {
        flex-shrink: 0;
    }
</style>

<div class="container-fluid pt-2 pb-4">
    
    @if (Model.Any())
    {
        await Html.RenderPartialAsync("_ViewToggle");

        <div class="view-cards">
            <div class="services-grid">
                @foreach (var item in Model)
                {
                    <div class="service-card-wrapper" onclick="location.href='/Services/Details/@item.ServiceCode'">
                        <div class="service-card">
                            <div class="card-top-row">
                                <span class="service-code-left">@item.ServiceCode</span>
                                <div class="service-name">@item.ServiceName</div>
                                <span class="service-duration">@(item.FixedDurationMin.HasValue ? item.FixedDurationMin + " мин" : "—")</span>
                            </div>
                            <div class="card-bottom-row">
                                <span class="service-cost">@item.ServiceCost.ToString("N0") ₽</span>
                                <div class="action-btns">
                                    <a asp-action="Edit" asp-route-id="@item.ServiceCode" class="action-btn" title="Редактировать" onclick="event.stopPropagation()">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <path d="M17 3a2.828 2.828 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5L17 3z"></path>
                                        </svg>
                                    </a>
                                    <button type="button" class="action-btn danger" title="Удалить" onclick="event.stopPropagation(); showDeleteModal(@item.ServiceCode, '@item.ServiceName')">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <polyline points="3 6 5 6 21 6"></polyline>
                                            <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                                            <line x1="10" y1="11" x2="10" y2="17"></line>
                                            <line x1="14" y1="11" x2="14" y2="17"></line>
                                        </svg>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                }
                <a asp-action="Create" class="service-card-wrapper add-card-wrapper">
                    <div class="service-card add-card">
                        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="12" y1="5" x2="12" y2="19"></line>
                            <line x1="5" y1="12" x2="19" y2="12"></line>
                        </svg>
                        <span>Добавить услугу</span>
                    </div>
                </a>
            </div>
        </div>

        <div class="view-table">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Код</th>
                        <th>Название</th>
                        <th>Длительность</th>
                        <th>Стоимость</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr onclick="location.href='/Services/Details/@item.ServiceCode'" style="cursor:pointer;">
                            <td data-label="Код">@item.ServiceCode</td>
                            <td data-label="Название">@item.ServiceName</td>
                            <td data-label="Длительность">@(item.FixedDurationMin.HasValue ? item.FixedDurationMin + " мин" : "—")</td>
                            <td data-label="Стоимость">@item.ServiceCost.ToString("N0") ₽</td>
                            <td data-label="">
                                <div class="table-actions" onclick="event.stopPropagation()">
                                    <a asp-action="Edit" asp-route-id="@item.ServiceCode" title="Редактировать">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.828 2.828 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5L17 3z"></path></svg>
                                    </a>
                                    <button class="danger" title="Удалить" onclick="showDeleteModal(@item.ServiceCode, '@item.ServiceName')">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="text-center py-5 border rounded bg-light">
            <i class="bi bi-gear text-muted" style="font-size: 3rem;"></i>
            <h4 class="mt-3">Услуги не найдены</h4>
            <p class="text-muted">Добавьте первую услугу в прайс-лист.</p>
            <a asp-action="Create" class="btn btn-dark mt-3"><i class="bi bi-plus-circle me-1"></i> Добавить</a>
        </div>
    }

</div>

<!-- Delete Modal -->
<div id="deleteModal" class="modal-overlay" style="display:none;" onclick="closeDeleteModal(event)">
    <div class="modal-content" onclick="event.stopPropagation()">
        <div class="modal-header">
            <h3 class="modal-title">Удалить услугу?</h3>
        </div>
        <div class="modal-body">
            <p class="modal-text">Вы уверены, что хотите удалить</p>
            <p id="deleteServiceInfo" class="modal-service-info"></p>
            <p class="modal-hint">Это действие нельзя отменить.</p>
        </div>
        <form id="deleteForm" method="post" asp-action="Delete" asp-controller="Services">
            @Html.AntiForgeryToken()
            <input type="hidden" id="deleteServiceId" name="id" value="" />
            <div class="modal-actions">
                <button type="button" class="modal-btn modal-btn-cancel" onclick="closeDeleteModal()">Отмена</button>
                <button type="submit" class="modal-btn modal-btn-delete">
                    <svg class="trash-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:16px;height:16px;">
                        <polyline points="3 6 5 6 21 6"></polyline>
                        <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                        <line x1="10" y1="11" x2="10" y2="17"></line>
                        <line x1="14" y1="11" x2="14" y2="17"></line>
                    </svg>
                    Удалить
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function showDeleteModal(serviceCode, serviceName) {
            document.getElementById('deleteServiceId').value = serviceCode;
            document.getElementById('deleteServiceInfo').textContent = serviceName;
            var modal = document.getElementById('deleteModal');
            modal.style.display = 'flex';
            setTimeout(function() { modal.classList.add('modal-show'); }, 10);
        }

        function closeDeleteModal(e) {
            if (e && e.target !== e.currentTarget) return;
            var modal = document.getElementById('deleteModal');
            modal.classList.remove('modal-show');
            setTimeout(function() { modal.style.display = 'none'; }, 300);
        }
    </script>
}
