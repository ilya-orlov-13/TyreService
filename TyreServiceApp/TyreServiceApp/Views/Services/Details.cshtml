@model TyreServiceApp.Models.Service
@{
    ViewData["Title"] = "Подробности об услуге";
}

<partial name="_FormStyles" />
<style>
    .details-row {
        display: flex;
        align-items: center;
        padding: 12px 0;
        border-bottom: 1px solid #f1f5f9;
    }

    .details-row:last-child {
        border-bottom: none;
    }

    .details-label {
        font-weight: 600;
        color: #64748b;
        font-size: 14px;
        min-width: 140px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .details-value {
        font-weight: 500;
        color: #1e293b;
        font-size: 16px;
    }

    .price-badge {
        background-color: #f0f9ff;
        color: #0369a1;
        padding: 6px 12px;
        border-radius: 6px;
        font-weight: 600;
        border: 1px solid #bae6fd;
    }
</style>

<div class="container-fluid pt-2 pb-4">
    <div class="main-3d-wrapper" style="--mw: 600px">
        <div class="main-3d-inner">
            
            <!-- Заголовок -->
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h3 class="fw-bold m-0">
                    <i class="bi bi-info-circle me-2"></i> Подробности об услуге
                </h3>
            </div>

            <!-- Детали услуги -->
            <div class="mb-4">
                <div class="details-row">
                    <div class="details-label">
                        <i class="bi bi-hash"></i> Код услуги:
                    </div>
                    <div class="details-value">
                        @Model.ServiceCode
                    </div>
                </div>
                
                <div class="details-row">
                    <div class="details-label">
                        <i class="bi bi-tools"></i> Название услуги:
                    </div>
                    <div class="details-value">
                        @Model.ServiceName
                    </div>
                </div>
                
                <div class="details-row">
                    <div class="details-label">
                        <i class="bi bi-currency-exchange"></i> Стоимость:
                    </div>
                    <div class="details-value">
                        <span class="price-badge">@Model.ServiceCost ₽</span>
                    </div>
                </div>
            </div>

            <!-- Кнопки действий -->
            <div class="d-flex gap-3 mt-4">
                <a asp-action="Edit" asp-route-id="@Model.ServiceCode" class="modern-btn modern-btn-primary">
                    <i class="bi bi-pencil"></i> Редактировать
                </a>
                <a asp-action="Index" class="modern-btn modern-btn-secondary">
                    <i class="bi bi-arrow-left"></i> Вернуться к списку
                </a>
            </div>

        </div>
    </div>
</div>