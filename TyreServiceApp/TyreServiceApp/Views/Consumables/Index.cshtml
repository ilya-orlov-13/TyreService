@model IEnumerable<TyreServiceApp.Models.Consumable>

@{
    ViewData["Title"] = "Расходники";
}

<partial name="_CardGridStyles" />
<style>
    .consumable-card-wrapper {
        cursor: pointer;
    }

    .add-card-wrapper {
        text-decoration: none;
        display: block;
    }

    .add-card {
        min-height: 100%;
        box-sizing: border-box;
    }

    .consumable-card {
        gap: 14px;
        cursor: pointer;
    }

    .card-top-row {
        display: flex;
        align-items: center;
        gap: 10px;
        width: 100%;
    }

    .consumable-name {
        flex: 1;
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        font-weight: 600;
        font-size: clamp(15px, 1.8vw, 20px);
        line-height: 1.15;
        color: #000000;
        text-align: left;
        user-select: none;
        min-width: 0;
    }

    .consumable-prices {
        display: flex;
        gap: 14px;
        font-size: 0.82rem;
    }

    .consumable-prices .price-item {
        display: flex;
        flex-direction: column;
        gap: 1px;
    }

    .consumable-prices .price-item .label {
        font-size: 0.7rem;
        color: #999;
        text-transform: uppercase;
        letter-spacing: 0.3px;
    }

    .consumable-prices .price-item .value {
        font-weight: 700;
        font-size: 1rem;
        color: #000;
    }

    .consumable-prices .price-item .value.markup {
        color: #059669;
    }

    .card-bottom-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 8px;
        width: 100%;
    }

    .action-btns {
        display: flex;
        gap: 6px;
        align-items: center;
    }

    .action-btn {
        background: none;
        border: 1.5px solid #ccc;
        border-radius: 10px;
        padding: 8px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s ease;
        color: #999;
        text-decoration: none;
    }

    .action-btn:hover {
        border-color: #000;
        background: #f5f5f5;
        color: #000;
    }

    .action-btn.danger:hover {
        border-color: #dc2626;
        background: #fef2f2;
        color: #dc2626;
    }

    .action-btn svg {
        width: 16px;
        height: 16px;
    }

    /* Delete modal styles */
    .modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0, 0, 0, 0.5);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 9999;
        opacity: 0;
        transition: opacity 0.3s ease;
    }

    .modal-overlay.modal-show {
        opacity: 1;
    }

    .modal-content {
        background: #fff;
        border-radius: 20px;
        padding: 32px;
        max-width: 420px;
        width: 90%;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
        position: relative;
        transform: translateY(10px);
        transition: transform 0.3s ease;
    }

    .modal-show .modal-content {
        transform: translateY(0);
    }

    .modal-header {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0;
        border: none;
        margin-bottom: 16px;
    }

    .modal-title {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        font-size: 20px;
        font-weight: 700;
        color: #111;
        margin: 0;
    }

    .modal-body {
        padding: 0;
        text-align: center;
        border: none;
    }

    .modal-text {
        font-size: 14px;
        color: #666;
        margin-bottom: 8px;
    }

    .modal-hint {
        font-size: 12px;
        color: #999;
        margin: 0;
    }

    .modal-actions {
        display: flex;
        gap: 10px;
        margin-top: 24px;
    }

    .modal-btn {
        flex: 1;
        padding: 12px;
        border: none;
        border-radius: 12px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
    }

    .modal-btn-cancel {
        background: #f0f0f0;
        color: #333;
    }

    .modal-btn-cancel:hover {
        background: #e0e0e0;
    }

    .modal-btn-delete {
        background: #dc2626;
        color: white;
    }

    .modal-btn-delete:hover {
        background: #b91c1c;
    }

    .trash-icon {
        flex-shrink: 0;
    }

    /* Inline editing styles */
    .ie-cell {
        cursor: pointer;
        position: relative;
    }

    .ie-cell:hover {
        outline: 1px dashed #999;
        outline-offset: -1px;
        border-radius: 4px;
    }

    .ie-cell .ie-input {
        position: absolute;
        top: 4px;
        left: 4px;
        right: 4px;
        bottom: 4px;
        border: 1.5px solid #000;
        border-radius: 6px;
        padding: 4px 8px;
        font-size: 13px;
        font-family: inherit;
        background: #fff;
        z-index: 2;
        min-width: 80px;
    }

    .data-table .ie-cell {
        padding: 0 !important;
    }

    .data-table .ie-cell .ie-display {
        padding: 12px 18px;
    }

    @@media (max-width: 768px) {
        .consumables-grid {
            grid-template-columns: 1fr;
            gap: 12px;
        }

        .consumable-card {
            padding: 16px;
        }

        .consumable-name {
            font-size: clamp(15px, 3vw, 20px);
        }

        .card-bottom-row {
            flex-direction: column;
            align-items: stretch;
            gap: 8px;
        }

        .action-btns {
            justify-content: flex-end;
        }
    }

    @@media (max-width: 480px) {
        .consumable-card {
            padding: 14px;
        }
    }
</style>

<div class="container-fluid pt-2 pb-4">
    
    @if (Model.Any())
    {
        { await Html.RenderPartialAsync("_ViewToggle"); }

        <div class="view-cards">
            <div class="consumables-grid">
                @foreach (var item in Model)
                {
                    <div class="consumable-card-wrapper">
                        <div class="consumable-card">
                            <div class="card-top-row">
                                <div class="consumable-name">@item.Name</div>
                            </div>
                            <div class="card-bottom-row">
                                <div class="consumable-prices">
                                    <div class="price-item">
                                        <span class="label">Закупка</span>
                                        <span class="value">@item.CostPrice.ToString("N2") ₽</span>
                                    </div>
                                    <div class="price-item">
                                        <span class="label">Продажа</span>
                                        <span class="value">@item.SellPrice.ToString("N2") ₽</span>
                                    </div>
                                    <div class="price-item">
                                        <span class="label">Наценка</span>
                                        <span class="value markup">@((item.SellPrice - item.CostPrice).ToString("N2")) ₽</span>
                                    </div>
                                </div>
                                <div class="action-btns">
                                    <button type="button" class="action-btn danger" title="Удалить" onclick="event.stopPropagation(); showDeleteModal(@item.ConsumableId, '@item.Name')">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <polyline points="3 6 5 6 21 6"></polyline>
                                            <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                                            <line x1="10" y1="11" x2="10" y2="17"></line>
                                            <line x1="14" y1="11" x2="14" y2="17"></line>
                                        </svg>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                }
                <a asp-action="Create" class="consumable-card-wrapper add-card-wrapper">
                    <div class="consumable-card add-card">
                        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="12" y1="5" x2="12" y2="19"></line>
                            <line x1="5" y1="12" x2="19" y2="12"></line>
                        </svg>
                        <span>Добавить расходник</span>
                    </div>
                </a>
            </div>
        </div>

        <div class="view-table">
            <table class="data-table" id="consumablesTable">
                <thead>
                    <tr>
                        <th>Название</th>
                        <th style="width:130px;">Закупка</th>
                        <th style="width:130px;">Продажа</th>
                        <th style="width:110px;">Наценка</th>
                        <th style="width:60px;"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td data-label="Название" class="ie-cell" data-id="@item.ConsumableId" data-field="name">
                                <span class="ie-display">@item.Name</span>
                            </td>
                            <td data-label="Закупка" class="ie-cell" data-id="@item.ConsumableId" data-field="costPrice">
                                <span class="ie-display">@item.CostPrice.ToString("N2") ₽</span>
                            </td>
                            <td data-label="Продажа" class="ie-cell" data-id="@item.ConsumableId" data-field="sellPrice">
                                <span class="ie-display">@item.SellPrice.ToString("N2") ₽</span>
                            </td>
                            <td data-label="Наценка" style="color:#059669;font-weight:600;">
                                @((item.SellPrice - item.CostPrice).ToString("N2")) ₽
                            </td>
                            <td data-label="">
                                <div class="table-actions">
                                    <button class="danger" title="Удалить" onclick="showDeleteModal(@item.ConsumableId, '@item.Name')">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="text-center py-5 border rounded bg-light">
            <i class="bi bi-box-seam text-muted" style="font-size: 3rem;"></i>
            <h4 class="mt-3">Расходники не найдены</h4>
            <p class="text-muted">Добавьте первый расходный материал.</p>
            <a asp-action="Create" class="btn btn-dark mt-3"><i class="bi bi-plus-circle me-1"></i> Добавить</a>
        </div>
    }
</div>

<!-- Delete Modal -->
<div id="deleteModal" class="modal-overlay" style="display:none;" onclick="closeDeleteModal(event)">
    <div class="modal-content" onclick="event.stopPropagation()">
        <div class="modal-header">
            <h3 class="modal-title">Удалить расходник?</h3>
        </div>
        <div class="modal-body">
            <p class="modal-text">Вы уверены, что хотите удалить</p>
            <p id="deleteConsumableInfo" style="font-size:16px;font-weight:600;color:#111;margin-bottom:4px;"></p>
            <p class="modal-hint">Это действие нельзя отменить.</p>
        </div>
        <form id="deleteForm" method="post" asp-action="Delete" asp-controller="Consumables">
            @Html.AntiForgeryToken()
            <input type="hidden" id="deleteConsumableId" name="id" value="" />
            <div class="modal-actions">
                <button type="button" class="modal-btn modal-btn-cancel" onclick="closeDeleteModal()">Отмена</button>
                <button type="submit" class="modal-btn modal-btn-delete">
                    <svg class="trash-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:16px;height:16px;">
                        <polyline points="3 6 5 6 21 6"></polyline>
                        <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                        <line x1="10" y1="11" x2="10" y2="17"></line>
                        <line x1="14" y1="11" x2="14" y2="17"></line>
                    </svg>
                    Удалить
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        // ---- Delete modal ----
        function showDeleteModal(id, name) {
            document.getElementById('deleteConsumableId').value = id;
            document.getElementById('deleteConsumableInfo').textContent = name;
            var modal = document.getElementById('deleteModal');
            modal.style.display = 'flex';
            setTimeout(function() { modal.classList.add('modal-show'); }, 10);
        }

        function closeDeleteModal(e) {
            if (e && e.target !== e.currentTarget) return;
            var modal = document.getElementById('deleteModal');
            modal.classList.remove('modal-show');
            setTimeout(function() { modal.style.display = 'none'; }, 300);
        }

        // ---- Inline editing ----
        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('.ie-cell').forEach(function (cell) {
                cell.addEventListener('click', function (e) {
                    if (cell.querySelector('.ie-input')) return;
                    var display = cell.querySelector('.ie-display');
                    if (!display) return;
                    var raw = display.textContent.trim().replace(/ ₽$/, '');
                    var input = document.createElement('input');
                    input.type = 'text';
                    input.className = 'ie-input';
                    input.value = raw;
                    input.setAttribute('autofocus', '');
                    display.style.visibility = 'hidden';
                    cell.appendChild(input);
                    input.focus();
                    input.select();

                    function save() {
                        var val = input.value.trim();
                        var id = cell.getAttribute('data-id');
                        var field = cell.getAttribute('data-field');
                        if (val !== raw && val !== '') {
                            var token = document.querySelector('input[name="__RequestVerificationToken"]');
                            var formData = new FormData();
                            formData.append('id', id);
                            formData.append('field', field);
                            formData.append('value', val);
                            if (token) formData.append('__RequestVerificationToken', token.value);
                            fetch('/Consumables/UpdateField/' + id + '?field=' + encodeURIComponent(field) + '&value=' + encodeURIComponent(val), {
                                method: 'POST',
                                headers: {
                                    'RequestVerificationToken': token ? token.value : ''
                                }
                            })
                            .then(function (r) { return r.json(); })
                            .then(function (data) {
                                if (data.success) {
                                    display.textContent = field === 'name' ? val : val + ' ₽';
                                }
                            })
                            .catch(function () {});
                        }
                        display.style.visibility = '';
                        input.remove();
                    }

                    input.addEventListener('blur', save);
                    input.addEventListener('keydown', function (ev) {
                        if (ev.key === 'Enter') { ev.preventDefault(); save(); }
                        if (ev.key === 'Escape') { ev.preventDefault(); display.style.visibility = ''; input.remove(); }
                    });
                });
            });
        });
    </script>
}