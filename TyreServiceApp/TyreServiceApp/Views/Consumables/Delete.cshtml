@model TyreServiceApp.Models.Consumable

@{
    ViewData["Title"] = "Удалить расходник";
}

<div class="container-fluid pt-2 pb-4" style="max-width: 500px;">
    <h3 class="fw-bold mb-4">
        <i class="bi bi-trash3 me-2"></i> Удалить расходник
    </h3>
    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <p class="mb-3">Вы уверены, что хотите удалить расходник <strong>@Model.Name</strong>?</p>
            <form asp-action="Delete">
                <input type="hidden" asp-for="ConsumableId" />
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-danger"><i class="bi bi-trash"></i> Удалить</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Отмена</a>
                </div>
            </form>
        </div>
    </div>
</div>
