@model TyreServiceApp.Models.Consumable

@{
    ViewData["Title"] = "Добавить расходник";
}

<div class="container-fluid pt-2 pb-4" style="max-width: 500px;">
    <h3 class="fw-bold mb-4">
        <i class="bi bi-box-seam me-2"></i> Добавить расходник
    </h3>
    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <div class="mb-3">
                    <label asp-for="Name" class="form-label fw-semibold"></label>
                    <input asp-for="Name" class="form-control" placeholder="Например, Моторное масло 5W-30" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="CostPrice" class="form-label fw-semibold">Закупочная цена</label>
                    <input asp-for="CostPrice" class="form-control" type="number" step="0.01" min="0" />
                    <span asp-validation-for="CostPrice" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="SellPrice" class="form-label fw-semibold">Цена продажи</label>
                    <input asp-for="SellPrice" class="form-control" type="number" step="0.01" min="0" />
                    <span asp-validation-for="SellPrice" class="text-danger"></span>
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-dark"><i class="bi bi-check-lg"></i> Создать</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Отмена</a>
                </div>
            </form>
        </div>
    </div>
</div>
