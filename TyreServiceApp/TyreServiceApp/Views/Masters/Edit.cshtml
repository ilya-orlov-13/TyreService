@model TyreServiceApp.Models.Master

@{
    ViewData["Title"] = "Редактировать мастера";
}

<partial name="_FormStyles" />

<div class="container-fluid pt-2 pb-4">
    <div class="main-3d-wrapper">
        <div class="main-3d-inner">
            
            <!-- Заголовок -->
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h3 class="fw-bold m-0">
                    Редактировать мастера
                </h3>
            </div>

            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="alert-danger" role="alert"></div>
                <input type="hidden" asp-for="MasterId" />
                
                <div class="row">
                    <div class="col-md-6">
                        <div class="modern-form-group">
                            <label asp-for="FullName" class="modern-form-label">
                                <i class="bi bi-person me-1"></i> ФИО
                            </label>
                            <input asp-for="FullName" class="modern-form-input" placeholder="Введите полное имя" />
                            <span asp-validation-for="FullName" class="validation-error"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="modern-form-group">
                            <label asp-for="PositionId" class="modern-form-label">
                                <i class="bi bi-briefcase me-1"></i> Должность
                            </label>
                            <select asp-for="PositionId" class="modern-form-input" asp-items="ViewBag.PositionId">
                                <option value="">Выберите должность...</option>
                            </select>
                            <span asp-validation-for="PositionId" class="validation-error"></span>
                        </div>
                    </div>
                </div>
                
                <div class="row">
                    <div class="col-md-6">
                        <div class="modern-form-group">
                            <label asp-for="Rank" class="modern-form-label">
                                <i class="bi bi-star me-1"></i> Разряд
                            </label>
                            <input asp-for="Rank" class="modern-form-input" type="number" placeholder="1-6" />
                            <span asp-validation-for="Rank" class="validation-error"></span>
                        </div>
                    </div>
                </div>
                
                <!-- Кнопки действий -->
                <div class="d-flex gap-2 mt-4 pt-2">
                    <button type="submit" class="btn btn-dark px-4">
                        <i class="bi bi-check-lg"></i> Сохранить изменения
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary px-4">
                        <i class="bi bi-x-lg"></i> Отмена
                    </a>
                </div>
            </form>

        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}