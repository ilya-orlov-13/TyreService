@model TyreServiceApp.Models.Master
@{
    ViewData["Title"] = "Подробности о мастере";
}

<partial name="_FormStyles" />
<style>
    .details-row {
        display: flex;
        align-items: center;
        padding: 12px 0;
        border-bottom: 1px solid #f1f5f9;
    }

    .details-row:last-child {
        border-bottom: none;
    }

    .details-label {
        font-weight: 600;
        color: #64748b;
        font-size: 14px;
        min-width: 160px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .details-value {
        font-weight: 500;
        color: #1e293b;
        font-size: 16px;
    }

    .rank-badge {
        background-color: #eff6ff;
        color: #1d4ed8;
        padding: 6px 12px;
        border-radius: 6px;
        font-weight: 600;
        border: 1px solid #bfdbfe;
    }

    .rate-badge {
        background-color: #f0fdf4;
        color: #166534;
        padding: 6px 12px;
        border-radius: 6px;
        font-weight: 600;
        border: 1px solid #bbf7d0;
    }
</style>

<div class="container-fluid pt-2 pb-4">
    <div class="main-3d-wrapper">
        <div class="main-3d-inner">
            
            <!-- Заголовок -->
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h3 class="fw-bold m-0">
                    <i class="bi bi-info-circle me-2"></i> Подробности о мастере
                </h3>
            </div>

            <!-- Детали мастера -->
            <div class="mb-4">
                <div class="details-row">
                    <div class="details-label">
                        <i class="bi bi-person"></i> ФИО:
                    </div>
                    <div class="details-value">
                        @Model.FullName
                    </div>
                </div>
                
                <div class="details-row">
                    <div class="details-label">
                        <i class="bi bi-briefcase"></i> Должность:
                    </div>
                    <div class="details-value">
                        @Model.Position?.Name
                    </div>
                </div>
                
                <div class="details-row">
                    <div class="details-label">
                        <i class="bi bi-star"></i> Разряд:
                    </div>
                    <div class="details-value">
                        <span class="rank-badge">@Model.Rank разряд</span>
                    </div>
                </div>
                
                <div class="details-row">
                    <div class="details-label">
                        <i class="bi bi-currency-exchange"></i> Почасовая ставка:
                    </div>
                    <div class="details-value">
                        <span class="rate-badge">@Model.HourlyRate ₽/ч</span>
                    </div>
                </div>
            </div>

            <!-- Кнопки действий -->
            <div class="d-flex gap-3 mt-4">
                <a asp-action="Edit" asp-route-id="@Model.MasterId" class="modern-btn modern-btn-primary">
                    <i class="bi bi-pencil"></i> Редактировать
                </a>
                @{
                    var returnUrl = Context.Request.Query["returnUrl"].FirstOrDefault();
                }
                <a href="@(returnUrl ?? Url.Action("Index"))" class="modern-btn modern-btn-secondary">
                    <i class="bi bi-arrow-left"></i> Вернуться к списку
                </a>
            </div>

        </div>
    </div>
</div>