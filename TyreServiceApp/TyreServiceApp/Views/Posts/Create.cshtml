@model TyreServiceApp.Models.Post

@{
    ViewData["Title"] = "Создать пост";
}

<partial name="_FormStyles" />

<div class="container-fluid pt-2 pb-4">
    <div class="main-3d-wrapper">
        <div class="main-3d-inner">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h3 class="fw-bold m-0">Создать пост</h3>
            </div>

            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="alert-danger" role="alert"></div>

                <div class="modern-form-group">
                    <label asp-for="Name" class="modern-form-label">
                        <i class="bi bi-tools me-1"></i> Название
                    </label>
                    <input asp-for="Name" class="modern-form-input" placeholder="Например, Пост №3" />
                    <span asp-validation-for="Name" class="validation-error"></span>
                </div>

                <div class="d-flex gap-2 mt-4 pt-2">
                    <button type="submit" class="btn btn-dark px-4">
                        <i class="bi bi-check-lg"></i> Создать
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary px-4">
                        <i class="bi bi-x-lg"></i> Отмена
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
