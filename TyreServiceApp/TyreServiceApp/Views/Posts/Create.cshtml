@model TyreServiceApp.Models.Post

@{
    ViewData["Title"] = "Создать пост";
}

<h2 class="fw-bold mb-3">Создать пост</h2>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Name" class="form-label fw-semibold"></label>
                <input asp-for="Name" class="form-control" placeholder="Например, Пост №3" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-dark">
                    <i class="bi bi-check-lg"></i> Создать
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">Отмена</a>
            </div>
        </form>
    </div>
</div>
