@model TyreServiceApp.Models.Tire

@{
    ViewData["Title"] = "Удалить шину";
}

<partial name="_FormStyles" />
<style>
    .modern-btn-danger {
        background-color: #dc2626;
        color: white;
    }

    .modern-btn-danger:hover {
        background-color: #b91c1c;
        transform: translateY(-1px);
    }

    .warning-alert {
        background-color: #fef3c7;
        border: 2px solid #f59e0b;
        border-radius: 8px;
        padding: 16px;
        margin-bottom: 24px;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .warning-alert-icon {
        color: #d97706;
        font-size: 20px;
        flex-shrink: 0;
    }

    .warning-alert-text {
        color: #92400e;
        font-weight: 500;
        font-size: 14px;
    }

    .details-row {
        display: flex;
        align-items: center;
        padding: 12px 0;
        border-bottom: 1px solid #f1f5f9;
    }

    .details-row:last-child {
        border-bottom: none;
    }

    .details-label {
        font-weight: 600;
        color: #64748b;
        font-size: 14px;
        min-width: 160px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .details-value {
        font-weight: 500;
        color: #1e293b;
        font-size: 16px;
    }

    .season-badge {
        padding: 6px 12px;
        border-radius: 6px;
        font-weight: 600;
        font-size: 12px;
        background-color: #f1f5f9;
        color: #475569;
        border: 1px solid #cbd5e1;
    }

    .size-badge {
        background-color: #f1f5f9;
        color: #475569;
        padding: 6px 12px;
        border-radius: 6px;
        font-weight: 600;
        border: 1px solid #cbd5e1;
        font-family: monospace;
    }
</style>

<div class="container-fluid pt-2 pb-4">
    <div class="main-3d-wrapper" style="--mw: 700px; --button_outline_color: #dc2626">
        <div class="main-3d-inner">
            
            <!-- Заголовок -->
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h3 class="fw-bold m-0">
                    <i class="bi bi-exclamation-triangle me-2"></i> Удаление шины
                </h3>
            </div>

            <!-- Предупреждение -->
            <div class="warning-alert">
                <i class="bi bi-exclamation-triangle-fill warning-alert-icon"></i>
                <div class="warning-alert-text">
                    <strong>Внимание!</strong> Вы уверены, что хотите удалить эту шину? Это действие нельзя отменить.
                </div>
            </div>

            <!-- Детали шины -->
            <div class="mb-4">
                <div class="details-row">
                    <div class="details-label">
                        <i class="bi bi-tag"></i> Тип шины:
                    </div>
                    <div class="details-value">
                        @Html.DisplayFor(model => model.TireType)
                    </div>
                </div>
                
                <div class="details-row">
                    <div class="details-label">
                        <i class="bi bi-snow"></i> Сезонность:
                    </div>
                    <div class="details-value">
                        <span class="season-badge">@Html.DisplayFor(model => model.Seasonality)</span>
                    </div>
                </div>
                
                <div class="details-row">
                    <div class="details-label">
                        <i class="bi bi-building"></i> Производитель:
                    </div>
                    <div class="details-value">
                        @Html.DisplayFor(model => model.Manufacturer)
                    </div>
                </div>
                
                <div class="details-row">
                    <div class="details-label">
                        <i class="bi bi-tag"></i> Модель шины:
                    </div>
                    <div class="details-value">
                        @Html.DisplayFor(model => model.TireModel)
                    </div>
                </div>
                
                <div class="details-row">
                    <div class="details-label">
                        <i class="bi bi-rulers"></i> Размер:
                    </div>
                    <div class="details-value">
                        <span class="size-badge">@Html.DisplayFor(model => model.Size)</span>
                    </div>
                </div>
            </div>

            <!-- Кнопки действий -->
            <form asp-action="Delete" class="d-flex gap-3 mt-4">
                <input type="hidden" asp-for="TireId" />
                <button type="submit" class="modern-btn modern-btn-danger">
                    <i class="bi bi-trash"></i> Удалить
                </button>
                <a asp-action="Index" class="modern-btn modern-btn-secondary">
                    <i class="bi bi-arrow-left"></i> Отмена
                </a>
            </form>

        </div>
    </div>
</div>