@section Styles {
    <link rel="stylesheet" href="~/css/pages/cars-index.css" asp-append-version="true" />
}

@model IEnumerable<TyreServiceApp.Models.Car>

@functions {
    string[] ParsePlate(string plate)
    {
        if (string.IsNullOrEmpty(plate) || plate.Length < 6)
            return new[] { plate ?? "", "", "", "" };
        var p = plate.Trim().ToUpperInvariant();
        return new[]
        {
            p.Length > 0 ? p[0].ToString() : "",
            p.Length > 3 ? p[1..4] : "",
            p.Length > 5 ? p[4..Math.Min(6, p.Length)] : "",
            p.Length > 6 ? p[6..] : ""
        };
    }

    string FormatShortName(string fullName)
    {
        if (string.IsNullOrWhiteSpace(fullName)) return "";
        var parts = fullName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length < 2) return fullName;
        var result = parts[0];
        for (int i = 1; i < parts.Length; i++)
        {
            if (parts[i].Length > 0)
                result += " " + parts[i][0] + ".";
        }
        return result;
    }
}

@{
    ViewData["Title"] = "Автомобили";
    var carsIndexUrl = Url.Action("Index", "Cars", new { area = "" });
}

<partial name="_CardGridStyles" />
<div class="container-fluid pt-2 pb-4">

    @if (Model.Any())
    {
        await Html.RenderPartialAsync("_ViewToggle");

        <div class="view-cards">
            <div class="cars-grid">
                @foreach (var item in Model)
                {
                    <div class="car-card-wrapper" onclick="handleCardClick(event, @item.CarId)">
                        <div class="car-card">
                            <div class="card-top-row">
                                <div class="car-image-wrapper">
                                    @{
                                        var allCarPhotos = new List<string>();
                                        if (!string.IsNullOrEmpty(item.PhotoPath))
                                        {
                                            allCarPhotos.Add(item.PhotoPath);
                                        }
                                        if (!string.IsNullOrEmpty(item.AdditionalPhotos))
                                        {
                                            try
                                            {
                                                var additionalPhotos = System.Text.Json.JsonSerializer.Deserialize<List<string>>(item.AdditionalPhotos);
                                                if (additionalPhotos != null)
                                                {
                                                    allCarPhotos.AddRange(additionalPhotos);
                                                }
                                            }
                                            catch { }
                                        }
                                    }
                                    
                                    @if (allCarPhotos.Count > 0)
                                    {
                                        <div class="car-image-preview" data-pv-photos='@Html.Raw(Json.Serialize(allCarPhotos))'>
                                            <img src="@allCarPhotos[0]" alt="@item.Brand @item.Model" class="car-image"
                                                 onclick="event.stopPropagation(); openPhotoViewer(this, @item.CarId)"
                                                 style="cursor: pointer;">
                                            @if (allCarPhotos.Count > 1)
                                            {
                                            <button class="pv-card-arrow pv-card-left" onclick="event.stopPropagation(); pvCardPrev(this)">
                                                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
                                            </button>
                                            <button class="pv-card-arrow pv-card-right" onclick="event.stopPropagation(); pvCardNext(this)">
                                                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
                                            </button>
                                            }
                                        </div>
                                        <script type="application/json" class="car-photos-data" data-car-id="@item.CarId">
                                            @Html.Raw(Json.Serialize(allCarPhotos))
                                        </script>
                                    }
                                    else
                                    {
                                        <img src="~/images/default-car.png" alt="@item.Brand @item.Model" class="car-image">
                                    }
                                </div>
                                <div class="brand-title">@item.Brand<br>@item.Model</div>
                                @if (item.Client != null)
                                {
                                    <span class="client-btn-wrap">
                                        <button type="button" class="client-btn" onclick="event.stopPropagation(); location.href='@Url.Action("Details", "Clients", new { area = "", id = item.ClientId })?returnUrl=@Uri.EscapeDataString(carsIndexUrl)'">
                                            <i class="bi bi-person me-1"></i>@FormatShortName(item.Client.FullName)
                                        </button>
                                        <div class="client-popup">
                                            @if (!string.IsNullOrEmpty(item.Client.Phone))
                                            {
                                                <div class="cp-row">
                                                    <i class="bi bi-telephone cp-icon"></i>
                                                    <span class="cp-value">@item.Client.Phone</span>
                                                     <button type="button" class="cp-copy" data-value="@item.Client.Phone" onclick="console.log('Phone copy button clicked'); event.stopPropagation(); copyContact(this)" title="Копировать">
                                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
                                                    </button>
                                                </div>
                                            }
                                            @if (!string.IsNullOrEmpty(item.Client.Email))
                                            {
                                                <div class="cp-row">
                                                    <i class="bi bi-envelope cp-icon"></i>
                                                    <span class="cp-value">@item.Client.Email</span>
                                                     <button type="button" class="cp-copy" data-value="@item.Client.Email" onclick="console.log('Email copy button clicked'); event.stopPropagation(); copyContact(this)" title="Копировать">
                                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
                                                    </button>
                                                </div>
                                            }
                                        </div>
                                    </span>
                                }
                            </div>
                            <div class="card-bottom-row">
                                <div class="detail-block plate-block">
                                    @{
                                        var pp = ParsePlate(item.LicensePlate);
                                    }
                                    <div class="plate-desktop">
                                    <div class="plate-wrapper">
                                    <div class="license-plate">
                                        <div class="inner-frame">
                                            <div class="left-section">
                                                <span class="letter">@pp[0]</span>
                                                <span class="digits">@pp[1]</span>
                                                <span class="letter">@pp[2]</span>
                                            </div>
                                            @if (!string.IsNullOrEmpty(pp[3]))
                                            {
                                                <div class="divider"></div>
                                                <div class="right-section">
                                                    <div class="region-code">@pp[3]</div>
                                                    <div class="country-block">
                                                        <span class="rus-text">RUS</span>
                                                        <div class="flag">
                                                            <div class="stripe white"></div>
                                                            <div class="stripe blue"></div>
                                                            <div class="stripe red"></div>
                                                        </div>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                    </div>
                                    </div>
                                </div>
                                <div style="display:flex;gap:6px;align-items:center" onclick="event.stopPropagation()">
                                    <a asp-area="" asp-controller="Cars" asp-action="Edit" asp-route-id="@item.CarId"
                                        class="delete-btn" aria-label="Редактировать"
                                        style="background:#fff;text-decoration:none;display:flex;align-items:center;justify-content:center;color:#999">
                                        <svg class="trash-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <path d="M17 3a2.828 2.828 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5L17 3z"></path>
                                        </svg>
                                    </a>
                                    <button type="button" class="delete-btn" aria-label="Удалить"
                                            onclick="event.stopPropagation(); showDeleteModal(@item.CarId, '@item.Brand @item.Model', '@item.LicensePlate')">
                                        <svg class="trash-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <polyline points="3 6 5 6 21 6"></polyline>
                                            <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                                            <line x1="10" y1="11" x2="10" y2="17"></line>
                                            <line x1="14" y1="11" x2="14" y2="17"></line>
                                        </svg>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                }
                <a href="/Cars/Create" class="car-card-wrapper add-card-wrapper">
                    <div class="car-card add-card">
                        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="12" y1="5" x2="12" y2="19"></line>
                            <line x1="5" y1="12" x2="19" y2="12"></line>
                        </svg>
                        <span>Добавить автомобиль</span>
                    </div>
                </a>
            </div>
        </div>

        <div class="view-table">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Марка</th>
                        <th>Модель</th>
                        <th>Госномер</th>
                        <th>Клиент</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr onclick="handleCardClick(event, @item.CarId)" style="cursor:pointer;">
                            <td data-label="Марка">@item.Brand</td>
                            <td data-label="Модель">@item.Model</td>
                            <td data-label="Госномер">@item.LicensePlate</td>
                            <td data-label="Клиент">@(item.Client != null ? item.Client.FullName : "—")</td>
                            <td data-label="">
                                <div class="table-actions" onclick="event.stopPropagation()">
                                    <a asp-area="" asp-controller="Cars" asp-action="Edit" asp-route-id="@item.CarId" title="Редактировать">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.828 2.828 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5L17 3z"></path></svg>
                                    </a>
                                    <button class="danger" title="Удалить" onclick="showDeleteModal(@item.CarId, '@item.Brand @item.Model', '@item.LicensePlate')">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="text-center py-5 border rounded bg-light">
            <i class="bi bi-car-front text-muted" style="font-size: 3rem;"></i>
            <h4 class="mt-3">Автомобили не найдены</h4>
            <p class="text-muted">Добавьте первый автомобиль, чтобы начать работу.</p>
            <a href="/Cars/Create" class="btn btn-dark mt-3"><i class="bi bi-plus-circle me-1"></i> Добавить</a>
        </div>
    }
</div>

<!-- Delete Modal -->
<div id="deleteModal" class="modal-overlay" style="display:none;" onclick="closeDeleteModal(event)">
    <div class="modal-content" onclick="event.stopPropagation()">
        <div class="modal-header">
            <h3 class="modal-title">Удалить автомобиль?</h3>
        </div>
        <div class="modal-body">
            <p class="modal-text">Вы уверены, что хотите удалить</p>
            <p id="deleteCarInfo" class="modal-car-info"></p>
            <p class="modal-hint">Это действие нельзя отменить.</p>
        </div>
        <form id="deleteForm" method="post" asp-area="" asp-controller="Cars" asp-action="Delete">
            @Html.AntiForgeryToken()
            <input type="hidden" id="deleteCarId" name="id" value="" />
            <div class="modal-actions">
                <button type="button" class="modal-btn modal-btn-cancel" onclick="closeDeleteModal()">Отмена</button>
                <button type="submit" class="modal-btn modal-btn-delete">
                    <svg class="trash-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:16px;height:16px;">
                        <polyline points="3 6 5 6 21 6"></polyline>
                        <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                        <line x1="10" y1="11" x2="10" y2="17"></line>
                        <line x1="14" y1="11" x2="14" y2="17"></line>
                    </svg>
                    Удалить
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Photo viewer overlay -->
<div id="photoViewer" class="photo-viewer" style="display:none;" onclick="closePhotoViewer(event)">
    <div class="photo-viewer-content" onclick="event.stopPropagation()">
        <img id="pvImage" src="" alt="Car Photo">
        <div class="pv-counter" id="pvCounter"></div>
        <div class="pv-nav-dots">
            <button class="pv-dot" id="pvPrevDot" onclick="pvPrev()">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
            </button>
            <button class="pv-dot" id="pvNextDot" onclick="pvNext()">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function handleCardClick(event, carId) {
            var target = event.target;
            if (target.closest('.delete-btn') || target.closest('.car-image') || target.closest('.pv-card-arrow') || target.closest('.client-btn') || target.closest('.client-btn-wrap')) {
                return;
            }
            location.href = '@Url.Action("Details", "Cars", new { area = "", id = "__ID__" })'.replace('__ID__', carId) + '?returnUrl=' + encodeURIComponent(window.location.href);
        }

        function showDeleteModal(carId, carName, plate) {
            document.getElementById('deleteCarId').value = carId;
            document.getElementById('deleteCarInfo').textContent = carName + ' (' + plate + ')';
            var modal = document.getElementById('deleteModal');
            modal.style.display = 'flex';
            setTimeout(function() { modal.classList.add('modal-show'); }, 10);
        }

        function closeDeleteModal(e) {
            if (e && e.target !== e.currentTarget) return;
            var modal = document.getElementById('deleteModal');
            modal.classList.remove('modal-show');
            setTimeout(function() { modal.style.display = 'none'; }, 300);
        }

        var pvPhotos = [];
        var pvIndex = 0;

        function openPhotoViewer(img, carId) {
            var el = document.querySelector('.car-photos-data[data-car-id="' + carId + '"]');
            if (!el) return;
            try {
                pvPhotos = JSON.parse(el.textContent.trim());
            } catch(e) { return; }
            if (pvPhotos.length === 0) return;
            var preview = img.closest('.car-image-preview');
            pvIndex = preview && preview.pvIndex != null ? preview.pvIndex : 0;
            showPvPhoto();
            document.getElementById('photoViewer').style.display = 'flex';
            document.body.style.overflow = 'hidden';
        }

        function pvCardPrev(btn) {
            var preview = btn.closest('.car-image-preview');
            if (!preview) return;
            var photos = JSON.parse(preview.getAttribute('data-pv-photos'));
            if (photos.length < 2) return;
            var idx = preview.pvIndex || 0;
            idx = (idx - 1 + photos.length) % photos.length;
            preview.pvIndex = idx;
            preview.querySelector('.car-image').setAttribute('src', photos[idx]);
        }

        function pvCardNext(btn) {
            var preview = btn.closest('.car-image-preview');
            if (!preview) return;
            var photos = JSON.parse(preview.getAttribute('data-pv-photos'));
            if (photos.length < 2) return;
            var idx = preview.pvIndex || 0;
            idx = (idx + 1) % photos.length;
            preview.pvIndex = idx;
            preview.querySelector('.car-image').setAttribute('src', photos[idx]);
        }

        function closePhotoViewer(e) {
            if (e && e.target !== e.currentTarget) return;
            document.getElementById('photoViewer').style.display = 'none';
            document.body.style.overflow = '';
        }

        function showPvPhoto() {
            document.getElementById('pvImage').src = pvPhotos[pvIndex];
            var counter = document.getElementById('pvCounter');
            counter.textContent = (pvIndex + 1) + ' из ' + pvPhotos.length;
            var hasNav = pvPhotos.length > 1;
            document.getElementById('pvPrevDot').style.display = hasNav ? '' : 'none';
            document.getElementById('pvNextDot').style.display = hasNav ? '' : 'none';
        }

        function pvPrev() {
            pvIndex = (pvIndex - 1 + pvPhotos.length) % pvPhotos.length;
            showPvPhoto();
        }

        function pvNext() {
            pvIndex = (pvIndex + 1) % pvPhotos.length;
            showPvPhoto();
        }

        document.addEventListener('keydown', function(e) {
            if (document.getElementById('photoViewer').style.display !== 'flex') return;
            if (e.key === 'Escape') closePhotoViewer();
            if (e.key === 'ArrowLeft') pvPrev();
            if (e.key === 'ArrowRight') pvNext();
        });

        function copyContact(btn) {
            var text = btn.getAttribute('data-value');
            console.log('copyContact called with text:', text);
            if (!text) {
                console.error('No text value found');
                return;
            }
            
            // Try modern clipboard API first
            if (navigator.clipboard && navigator.clipboard.writeText) {
                navigator.clipboard.writeText(text).then(function() {
                    btn.classList.add('cp-copied');
                    var svg = btn.querySelector('svg');
                    var orig = svg.outerHTML;
                    svg.outerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>';
                    setTimeout(function() {
                        btn.classList.remove('cp-copied');
                        var check = btn.querySelector('svg');
                        if (check) check.outerHTML = orig;
                    }, 1200);
                    console.log('Copied successfully via Clipboard API');
                }).catch(function(err) {
                    console.error('Clipboard API failed, trying fallback:', err);
                    fallbackCopy(text, btn);
                });
            } else {
                console.log('Clipboard API not available, using fallback');
                fallbackCopy(text, btn);
            }
        }
        
        function fallbackCopy(text, btn) {
            var tempInput = document.createElement('textarea');
            tempInput.value = text;
            tempInput.style.position = 'fixed';
            tempInput.style.opacity = '0';
            document.body.appendChild(tempInput);
            tempInput.focus();
            tempInput.select();
            
            try {
                document.execCommand('copy');
                btn.classList.add('cp-copied');
                var svg = btn.querySelector('svg');
                var orig = svg.outerHTML;
                svg.outerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>';
                setTimeout(function() {
                    btn.classList.remove('cp-copied');
                    var check = btn.querySelector('svg');
                    if (check) check.outerHTML = orig;
                }, 1200);
                console.log('Copied successfully via fallback');
            } catch (err) {
                console.error('Fallback copy failed:', err);
                alert('Не удалось скопировать: ' + text);
            } finally {
                document.body.removeChild(tempInput);
            }
        }
    </script>
}