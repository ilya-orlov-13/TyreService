@model TyreServiceApp.Models.Car

@functions {
    string[] ParsePlate(string plate)
    {
        if (string.IsNullOrEmpty(plate) || plate.Length < 6)
            return new[] { plate ?? "", "", "", "" };
        var p = plate.Trim().ToUpperInvariant();
        return new[]
        {
            p.Length > 0 ? p[0].ToString() : "",
            p.Length > 3 ? p[1..4] : "",
            p.Length > 5 ? p[4..Math.Min(6, p.Length)] : "",
            p.Length > 6 ? p[6..] : ""
        };
    }
}

@{
    ViewData["Title"] = "Подробности об автомобиле";

    var allPhotos = new List<string>();
    if (!string.IsNullOrEmpty(Model.PhotoPath))
        allPhotos.Add(Model.PhotoPath);
    if (!string.IsNullOrEmpty(Model.AdditionalPhotos))
    {
        try
        {
            var additionalPhotos = System.Text.Json.JsonSerializer.Deserialize<List<string>>(Model.AdditionalPhotos);
            if (additionalPhotos != null)
                allPhotos.AddRange(additionalPhotos);
        }
        catch { }
    }

    var returnUrl = Context.Request.Query["returnUrl"].FirstOrDefault() ?? Url.Action("Index", "Cars", new { area = "" });
    var pp = ParsePlate(Model.LicensePlate);
}

<style>
    @@font-face {
        font-family: 'RoadNumbersCyr';
        src: url('/fonts/roadnumberscyr_regular.otf') format('opentype');
        font-weight: normal;
        font-style: normal;
    }

    .modal-page-overlay {
        position: fixed;
        top: 0; left: 0; right: 0; bottom: 0;
        background: rgba(0,0,0,0.5);
        backdrop-filter: blur(4px);
        -webkit-backdrop-filter: blur(4px);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 9998;
        animation: overlayFadeIn 0.25s ease;
    }
    @@keyframes overlayFadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
    }

    .modal-card {
        background: #fff;
        border-radius: 20px;
        max-width: 680px;
        width: 95%;
        max-height: 90vh;
        overflow-y: auto;
        box-shadow: 0 25px 80px rgba(0,0,0,0.3);
        animation: cardSlideUp 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    }
    @@keyframes cardSlideUp {
        from { opacity: 0; transform: translateY(24px) scale(0.96); }
        to { opacity: 1; transform: translateY(0) scale(1); }
    }

    .modal-card::-webkit-scrollbar { width: 6px; }
    .modal-card::-webkit-scrollbar-track { background: transparent; }
    .modal-card::-webkit-scrollbar-thumb { background: #d0d0d0; border-radius: 3px; }

    .modal-header-bar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 20px 24px 0;
    }
    .modal-header-bar h3 {
        font-size: 20px;
        font-weight: 800;
        margin: 0;
        color: #0f172a;
    }
    .modal-close-btn {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        border: none;
        background: #f1f5f9;
        color: #64748b;
        font-size: 20px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s;
        flex-shrink: 0;
    }
    .modal-close-btn:hover {
        background: #e2e8f0;
        color: #0f172a;
    }

    .modal-body {
        padding: 16px 24px 24px;
    }

    .car-title-section {
        background: #f8fafc;
        border-radius: 14px;
        padding: 20px;
        text-align: center;
        margin-bottom: 20px;
    }
    .car-title-section .car-model-name {
        font-size: 24px;
        font-weight: 800;
        color: #0f172a;
        margin: 0 0 4px;
    }

    .plate-desktop {
        display: inline-block;
        perspective: 1000px;
    }
    .plate-wrapper {
        transform-origin: left center;
    }
    .license-plate {
        display: inline-flex;
        box-sizing: border-box;
        font-family: "RoadNumbersCyr", "Arial", sans-serif;
        user-select: none;
        max-width: 100%;
        position: relative;
        transform-style: preserve-3d;
        overflow: hidden;
    }
    .license-plate .inner-frame {
        display: flex;
        border: 3px solid #111111;
        border-radius: 6px;
        box-sizing: border-box;
        overflow: hidden;
        background: linear-gradient(135deg, #fcfcfc 0%, #f5f5f5 40%, #efefef 100%);
        box-shadow:
            inset 0 1px 0 rgba(255,255,255,0.9),
            inset 0 -1px 0 rgba(0,0,0,0.04),
            0 2px 4px rgba(0,0,0,0.12),
            0 1px 2px rgba(0,0,0,0.08);
        position: relative;
    }
    .license-plate .inner-frame::after {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0; bottom: 0;
        background: repeating-linear-gradient(
            90deg,
            transparent,
            transparent 2px,
            rgba(255,255,255,0.15) 2px,
            rgba(255,255,255,0.15) 3px
        );
        pointer-events: none;
        z-index: 1;
    }
    .license-plate .left-section {
        flex: 1;
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        padding: 0 10px 10px 10px;
        box-sizing: border-box;
        position: relative;
        z-index: 2;
    }
    .license-plate .letter {
        font-family: "RoadNumbersCyr", "Arial", sans-serif;
        font-size: 42px;
        line-height: 1;
        letter-spacing: 0.1em;
        color: #000000;
    }
    .license-plate .digits {
        font-family: "RoadNumbersCyr", "Arial", sans-serif;
        font-size: 50px;
        line-height: 1;
        letter-spacing: 0.1em;
        color: #000000;
    }
    .license-plate .divider {
        width: 3px;
        flex-shrink: 0;
        background: #111111;
        position: relative;
        z-index: 2;
    }
    .license-plate .right-section {
        width: 60px;
        flex-shrink: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: space-between;
        padding: 6px 6px 6px 6px;
        box-sizing: border-box;
        position: relative;
        z-index: 2;
    }
    .license-plate .region-code {
        font-family: "RoadNumbersCyr", "Arial", sans-serif;
        font-size: 30px;
        font-weight: 400;
        line-height: 1;
        color: #000000;
        margin-top: 2px;
    }
    .license-plate .country-block {
        display: flex;
        align-items: center;
        gap: 3px;
        box-sizing: border-box;
    }
    .license-plate .rus-text {
        font-family: "Arial", sans-serif;
        font-size: 10px;
        font-weight: 700;
        line-height: 1;
        color: #0d0d0d;
        text-shadow: 0 1px 0 rgba(255,255,255,0.8);
    }
    .license-plate .flag {
        width: 12px;
        height: 7px;
        border: 1px solid #000000;
        display: flex;
        flex-direction: column;
        box-sizing: border-box;
        border-radius: 1px;
    }
    .js-tilt-glare {
        z-index: 3 !important;
    }
    .js-tilt-glare-inner {
        mix-blend-mode: screen !important;
        background-image: linear-gradient(180deg, rgba(255,255,255,0) 0%, rgba(255,255,255,0.9) 50%, rgba(255,255,255,0) 100%) !important;
        transition: opacity 0.35s ease-out !important;
    }
    .license-plate .stripe { flex: 1; }
    .license-plate .stripe.white { background: #ffffff; }
    .license-plate .stripe.blue { background: #0039a6; }
    .license-plate .stripe.red { background: #d52b1e; }

    .info-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
        margin-bottom: 20px;
    }
    .info-item {
        background: #f8fafc;
        border-radius: 12px;
        padding: 14px 16px;
    }
    .info-item .info-label {
        font-size: 11px;
        font-weight: 600;
        color: #94a3b8;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 4px;
    }
    .info-item .info-value {
        font-size: 16px;
        font-weight: 600;
        color: #0f172a;
    }
    .info-item.full-width {
        grid-column: 1 / -1;
    }

    .client-info-box {
        display: flex;
        align-items: center;
        gap: 12px;
    }
    .client-info-box .client-avatar {
        width: 44px;
        height: 44px;
        border-radius: 50%;
        background: #e2e8f0;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #64748b;
        flex-shrink: 0;
    }
    .client-info-box .client-details {
        flex: 1;
        min-width: 0;
    }
    .client-info-box .client-name-text {
        font-weight: 600;
        color: #0f172a;
    }
    .client-info-box .client-contact {
        font-size: 12px;
        color: #64748b;
    }

    .photo-gallery {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(90px, 1fr));
        gap: 8px;
        margin-bottom: 20px;
    }
    .photo-item {
        position: relative;
        cursor: pointer;
        border-radius: 10px;
        overflow: hidden;
        aspect-ratio: 4/3;
        background: #f1f5f9;
        transition: transform 0.2s;
    }
    .photo-item:hover {
        transform: scale(1.05);
    }
    .photo-thumbnail {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }
    .photo-count-badge {
        position: absolute;
        bottom: 4px;
        right: 4px;
        background: rgba(0,0,0,0.6);
        color: #fff;
        font-size: 10px;
        font-weight: 700;
        padding: 2px 6px;
        border-radius: 6px;
    }

    .modal-actions {
        display: flex;
        gap: 10px;
        padding-top: 16px;
        border-top: 1px solid #e2e8f0;
    }
    .modal-actions .btn {
        flex: 1;
        padding: 10px 16px;
        border-radius: 10px;
        font-weight: 600;
        font-size: 13px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        text-decoration: none;
        transition: all 0.2s;
        cursor: pointer;
        border: none;
    }
    .modal-actions .btn-primary {
        background: #000;
        color: #fff;
    }
    .modal-actions .btn-primary:hover {
        background: #333;
    }
    .modal-actions .btn-secondary {
        background: #f1f5f9;
        color: #1e293b;
    }
    .modal-actions .btn-secondary:hover {
        background: #e2e8f0;
    }

    /* Photo viewer (lightbox) */
    .photo-viewer {
        position: fixed;
        top: 0; left: 0; right: 0; bottom: 0;
        background: rgba(0,0,0,0.9);
        z-index: 99999;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .photo-viewer-content {
        position: relative;
        display: flex;
        flex-direction: column;
        align-items: center;
        max-width: 90vw;
        max-height: 90vh;
    }
    .photo-viewer-content img {
        max-width: 90vw;
        max-height: 80vh;
        object-fit: contain;
        border-radius: 8px;
    }
    .pv-counter {
        color: #aaa;
        font-size: 13px;
        margin-top: 10px;
        font-weight: 500;
    }
    .pv-nav-dots {
        display: flex;
        gap: 20px;
        margin-top: 12px;
    }
    .pv-dot {
        width: 44px;
        height: 44px;
        border-radius: 50%;
        background: none;
        border: 1.5px solid rgba(255,255,255,0.4);
        color: rgba(255,255,255,0.7);
        font-size: 22px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background 0.2s, border-color 0.2s, color 0.2s;
    }
    .pv-dot:hover {
        background: rgba(255,255,255,0.1);
        border-color: #fff;
        color: #fff;
    }

    @@media (max-width: 576px) {
        .modal-card { max-width: 100%; width: 100%; max-height: 100vh; border-radius: 0; }
        .modal-header-bar { padding: 16px 16px 0; }
        .modal-body { padding: 12px 16px 16px; }
        .info-grid { grid-template-columns: 1fr; }
        .car-title-section .car-model-name { font-size: 20px; }
        .modal-actions { flex-direction: column; }
    }
</style>

<div class="modal-page-overlay" onclick="closeModal(event)">
    <div class="modal-card" onclick="event.stopPropagation()">
        <div class="modal-header-bar">
            <h3><i class="bi bi-car-front-fill me-2"></i>@Model.Brand @Model.Model</h3>
            <a href="@returnUrl" class="modal-close-btn" aria-label="Закрыть">
                <i class="bi bi-x-lg"></i>
            </a>
        </div>

        <div class="modal-body">
            @if (allPhotos.Count > 0)
            {
                <div class="photo-gallery">
                    @for (int i = 0; i < allPhotos.Count; i++)
                    {
                        <div class="photo-item" onclick="openDetailViewer(@i)">
                            <img src="@allPhotos[i]" alt="Фото @(i + 1)" class="photo-thumbnail" />
                            @if (allPhotos.Count > 1 && i == 0)
                            {
                                <span class="photo-count-badge">+@(allPhotos.Count - 1)</span>
                            }
                        </div>
                    }
                </div>
            }
            <script type="application/json" id="detailPhotosData">
                @Html.Raw(Json.Serialize(allPhotos))
            </script>

            <div class="car-title-section">
                <div class="car-model-name">@Model.Brand @Model.Model</div>
                <div class="plate-desktop">
                <div class="plate-wrapper">
                <div class="license-plate" data-tilt data-tilt-max="12" data-tilt-glare="true" data-tilt-max-glare="0.5" data-tilt-scale="1" data-tilt-speed="600" data-tilt-perspective="1000">
                    <div class="inner-frame">
                        <div class="left-section">
                            <span class="letter">@pp[0]</span>
                            <span class="digits">@pp[1]</span>
                            <span class="letter">@pp[2]</span>
                        </div>
                        @if (!string.IsNullOrEmpty(pp[3]))
                        {
                            <div class="divider"></div>
                            <div class="right-section">
                                <div class="region-code">@pp[3]</div>
                                <div class="country-block">
                                    <span class="rus-text">RUS</span>
                                    <div class="flag">
                                        <div class="stripe white"></div>
                                        <div class="stripe blue"></div>
                                        <div class="stripe red"></div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
                </div>
                </div>
            </div>

            <div class="info-grid">
                <div class="info-item">
                    <div class="info-label">Год выпуска</div>
                    <div class="info-value">@(Model.ManufactureYear > 0 ? Model.ManufactureYear.ToString() : "—")</div>
                </div>
                <div class="info-item">
                    <div class="info-label">VIN</div>
                    <div class="info-value" style="font-family:monospace;font-size:14px;">@(string.IsNullOrEmpty(Model.Vin) ? "—" : Model.Vin)</div>
                </div>
                @if (Model.Client != null)
                {
                    <div class="info-item full-width">
                        <div class="info-label">Клиент</div>
                        <div class="client-info-box">
                            <div class="client-avatar">
                                <i class="bi bi-person-fill"></i>
                            </div>
                            <div class="client-details">
                                <div class="client-name-text">@Model.Client.FullName</div>
                                @if (!string.IsNullOrEmpty(Model.Client.Phone))
                                {
                                    <div class="client-contact">
                                        <i class="bi bi-telephone me-1"></i>@Model.Client.Phone
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(Model.Client.Email))
                                {
                                    <div class="client-contact">
                                        <i class="bi bi-envelope me-1"></i>@Model.Client.Email
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>

            <div class="modal-actions">
                <a asp-area="" asp-controller="Cars" asp-action="Edit" asp-route-id="@Model.CarId" class="btn btn-primary">
                    <i class="bi bi-pencil"></i> Редактировать
                </a>
                <a href="@returnUrl" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i> Назад
                </a>
            </div>
        </div>
    </div>
</div>

<!-- Photo viewer overlay -->
<div id="detailPhotoViewer" class="photo-viewer" style="display:none;" onclick="closeDetailViewer(event)">
    <div class="photo-viewer-content" onclick="event.stopPropagation()">
        <img id="detailPvImage" src="" alt="Car Photo">
        <div class="pv-counter" id="detailPvCounter"></div>
        <div class="pv-nav-dots">
            <button class="pv-dot" id="detailPvPrev" onclick="detailPvPrev()">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
            </button>
            <button class="pv-dot" id="detailPvNext" onclick="detailPvNext()">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/vanilla-tilt.js"></script>
    <script>
        function closeModal(e) {
            if (e && e.target !== e.currentTarget) return;
            window.location.href = '@returnUrl';
        }

        var detailPhotos = [];
        var detailPvIndex = 0;

        function openDetailViewer(index) {
            var el = document.getElementById('detailPhotosData');
            if (!el) return;
            try { detailPhotos = JSON.parse(el.textContent.trim()); } catch(e) { return; }
            if (detailPhotos.length === 0) return;
            detailPvIndex = index;
            detailShowPvPhoto();
            document.getElementById('detailPhotoViewer').style.display = 'flex';
            document.body.style.overflow = 'hidden';
        }

        function closeDetailViewer(e) {
            if (e && e.target !== e.currentTarget) return;
            document.getElementById('detailPhotoViewer').style.display = 'none';
            document.body.style.overflow = '';
        }

        function detailShowPvPhoto() {
            document.getElementById('detailPvImage').src = detailPhotos[detailPvIndex];
            document.getElementById('detailPvCounter').textContent = (detailPvIndex + 1) + ' из ' + detailPhotos.length;
            var hasNav = detailPhotos.length > 1;
            document.getElementById('detailPvPrev').style.display = hasNav ? '' : 'none';
            document.getElementById('detailPvNext').style.display = hasNav ? '' : 'none';
        }

        function detailPvPrev() { detailPvIndex = (detailPvIndex - 1 + detailPhotos.length) % detailPhotos.length; detailShowPvPhoto(); }
        function detailPvNext() { detailPvIndex = (detailPvIndex + 1) % detailPhotos.length; detailShowPvPhoto(); }

        document.addEventListener('keydown', function(e) {
            if (document.getElementById('detailPhotoViewer').style.display === 'flex') {
                if (e.key === 'Escape') closeDetailViewer(e);
                if (e.key === 'ArrowLeft') detailPvPrev();
                if (e.key === 'ArrowRight') detailPvNext();
                return;
            }
            if (e.key === 'Escape') closeModal(e);
        });
    </script>
}
