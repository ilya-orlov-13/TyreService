@model TyreServiceApp.Models.Order

@{
    ViewData["Title"] = "Создать заказ";
}

<partial name="_FormStyles" />
<style>
    .car-selector-container {
        margin-bottom: 20px;
        max-width: 320px;
    }

    .car-collapsible {
        background-color: #fafafa;
        color: #333;
        cursor: pointer;
        padding: 12px 16px;
        width: 100%;
        border: 2px solid #e1e5e9;
        border-radius: 8px;
        text-align: left;
        font-size: 14px;
        outline: none;
        display: flex;
        justify-content: space-between;
        align-items: center;
        transition: all 0.3s ease;
        min-height: 48px;
    }

    .car-collapsible:hover {
        background-color: #f0f0f0;
        border-color: #000000;
    }

    .car-collapsible.active {
        background-color: #f5f5f5;
        border-color: #000000;
        border-bottom-left-radius: 0;
        border-bottom-right-radius: 0;
    }

    .car-collapsible-text {
        flex: 1;
        text-align: left;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .car-collapsible-icon {
        transition: transform 0.3s ease;
        font-size: 16px;
        margin-left: 8px;
        flex-shrink: 0;
    }

    .car-collapsible.active .car-collapsible-icon {
        transform: rotate(180deg);
    }

    .car-content {
        max-height: 0;
        overflow: hidden;
        transition: max-height 0.35s ease-in-out;
        border: none;
        border-radius: 0 0 8px 8px;
        background: white;
        box-shadow: none;
    }

    .car-content.active {
        border: 2px solid #000000;
        border-top: none;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    }

    .car-search-container {
        padding: 12px;
        border-bottom: 1px solid #eee;
        background-color: #f8f9fa;
    }

    .car-search-input {
        width: 100%;
        padding: 8px 12px;
        border: 1px solid #ddd;
        border-radius: 6px;
        font-size: 13px;
        outline: none;
        transition: border-color 0.2s ease;
    }

    .car-search-input:focus {
        border-color: #000000;
        box-shadow: 0 0 0 2px rgba(0, 0, 0, 0.15);
    }

    .car-options-list {
        max-height: 240px;
        overflow-y: auto;
        background: white;
    }

    .car-option {
        padding: 10px 12px;
        cursor: pointer;
        border-bottom: 1px solid #f0f0f0;
        display: flex;
        align-items: center;
        gap: 10px;
        transition: all 0.2s ease;
    }

    .car-option:hover {
        background-color: #f8f9fa;
    }

    .car-option.selected {
        background-color: #f0f0f0;
        border-left: 3px solid #000000;
    }

    .car-option:last-child {
        border-bottom: none;
    }

    .car-option-photo {
        width: 40px;
        height: 28px;
        object-fit: cover;
        border-radius: 4px;
        border: 1px solid #ddd;
        flex-shrink: 0;
    }

    .car-option-placeholder {
        width: 40px;
        height: 28px;
        background-color: #f8f9fa;
        border: 1px solid #ddd;
        border-radius: 4px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #6c757d;
        flex-shrink: 0;
        font-size: 12px;
    }

    .car-option-info {
        flex: 1;
        min-width: 0;
    }

    .car-option-title {
        font-weight: 600;
        color: #212529;
        margin-bottom: 2px;
        font-size: 13px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .car-option-details {
        font-size: 11px;
        color: #6c757d;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .selected-car-display {
        color: #000000;
        font-weight: 500;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .selected-car-photo {
        width: 24px;
        height: 16px;
        object-fit: cover;
        border-radius: 3px;
        border: 1px solid #000000;
    }

    .car-options-list::-webkit-scrollbar {
        width: 6px;
    }

    .car-options-list::-webkit-scrollbar-track {
        background: #f1f1f1;
        border-radius: 3px;
    }

    .car-options-list::-webkit-scrollbar-thumb {
        background: #c1c1c1;
        border-radius: 3px;
    }

    .car-options-list::-webkit-scrollbar-thumb:hover {
        background: #a8a8a8;
    }

    /* Стили для форм */
    .modern-form-group {
        margin-bottom: 20px;
    }

    .modern-form-label {
        display: block;
        margin-bottom: 8px;
        font-weight: 600;
        color: #333;
        font-size: 14px;
    }

    .modern-form-input {
        width: 100%;
        padding: 12px 16px;
        border: 2px solid #e1e5e9;
        border-radius: 8px;
        font-size: 14px;
        transition: all 0.3s ease;
        background-color: #fff;
    }

    .modern-form-input:focus {
        outline: none;
        border-color: #000000;
        box-shadow: 0 0 0 3px rgba(0, 0, 0, 0.1);
    }

    .modern-form-select {
        width: 100%;
        padding: 12px 16px;
        border: 2px solid #e1e5e9;
        border-radius: 8px;
        font-size: 14px;
        background-color: #fff;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .modern-form-select:focus {
        outline: none;
        border-color: #000000;
        box-shadow: 0 0 0 3px rgba(0, 0, 0, 0.1);
    }

    .modern-btn {
        padding: 12px 24px;
        border: none;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        text-decoration: none;
    }

    .modern-btn-primary {
        background-color: #000000;
        color: white;
    }

    .modern-btn-primary:hover {
        background-color: #333333;
        transform: translateY(-1px);
    }

    .modern-btn-secondary {
        background-color: #6c757d;
        color: white;
    }

    .modern-btn-secondary:hover {
        background-color: #545b62;
        transform: translateY(-1px);
        color: white;
        text-decoration: none;
    }

    .form-text-helper {
        font-size: 12px;
        color: #6c757d;
        margin-top: 4px;
    }

    .validation-error {
        color: #dc3545;
        font-size: 12px;
        margin-top: 4px;
    }

    .alert-danger {
        background-color: #f8d7da;
        border: 1px solid #f5c6cb;
        color: #721c24;
        padding: 12px 16px;
        border-radius: 8px;
        margin-bottom: 20px;
    }

    #selectedCarId {
        display: none;
    }

    /* Стили для календаря */
    .calendar-container {
        position: relative;
        max-width: 280px;
    }

    .calendar-input {
        cursor: pointer;
        background-color: #fff;
    }

    .calendar-input:focus {
        cursor: pointer;
    }

    .calendar-popup {
        position: absolute;
        top: 100%;
        left: 0;
        width: 280px;
        background: white;
        border: 2px solid #000000;
        border-radius: 12px;
        box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
        z-index: 1000;
        padding: 16px;
        margin-top: 4px;
        opacity: 0;
        visibility: hidden;
        transform: translateY(-10px);
        transition: all 0.3s ease;
    }

    .calendar-popup.active {
        opacity: 1;
        visibility: visible;
        transform: translateY(0);
    }

    .calendar-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 16px;
    }

    .calendar-nav-btn {
        background: none;
        border: none;
        padding: 6px;
        border-radius: 6px;
        cursor: pointer;
        transition: background-color 0.2s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 28px;
        height: 28px;
    }

    .calendar-nav-btn:hover {
        background-color: #f1f5f9;
    }

    .calendar-month-year {
        font-size: 14px;
        font-weight: 600;
        color: #1e293b;
        margin: 0;
    }

    .calendar-weekdays {
        display: grid;
        grid-template-columns: repeat(7, 1fr);
        gap: 2px;
        margin-bottom: 6px;
    }

    .calendar-weekday {
        text-align: center;
        font-size: 10px;
        font-weight: 500;
        color: #64748b;
        padding: 6px 0;
    }

    .calendar-grid {
        display: grid;
        grid-template-columns: repeat(7, 1fr);
        gap: 2px;
    }

    .calendar-day {
        height: 28px;
        width: 28px;
        border: none;
        background: none;
        border-radius: 6px;
        font-size: 12px;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s ease;
        color: #374151;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto;
    }

    .calendar-day:hover:not(.empty):not(.today) {
        background-color: #e2e8f0;
    }

    .calendar-day.today {
        background-color: #000000;
        color: white;
    }

    .calendar-day.selected {
        background-color: #0f172a !important;
        color: white;
    }

    .calendar-day.empty {
        cursor: default;
    }

    .calendar-day.other-month {
        color: #cbd5e1;
    }

    /* Закрытие календаря при клике вне */
    .calendar-overlay {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        z-index: 999;
        display: none;
    }

    .calendar-overlay.active {
        display: block;
    }

    /* Стили для выбора времени в календаре */
    .calendar-time-section {
        margin-top: 12px;
        padding-top: 12px;
        border-top: 1px solid #e2e8f0;
    }

    .calendar-time-label {
        font-size: 12px;
        font-weight: 500;
        color: #64748b;
        margin-bottom: 8px;
        text-align: center;
    }

    .calendar-time-inputs {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 4px;
    }

    .calendar-time-input {
        width: 40px;
        height: 28px;
        border: 1px solid #d1d5db;
        border-radius: 4px;
        text-align: center;
        font-size: 12px;
        font-weight: 500;
        background: white;
        outline: none;
        transition: border-color 0.2s ease;
    }

    .calendar-time-input:focus {
        border-color: #000000;
        box-shadow: 0 0 0 2px rgba(0, 0, 0, 0.1);
    }

    .calendar-time-separator {
        font-size: 14px;
        font-weight: 600;
        color: #374151;
    }
</style>

<div class="container-fluid pt-2 pb-4">
    <div class="main-3d-wrapper" style="--mw: 700px">
        <div class="main-3d-inner">
            
            <!-- Заголовок -->
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h3 class="fw-bold m-0">
                    Создать новый заказ
                </h3>
            </div>

            <form asp-area="" asp-controller="Orders" asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="alert-danger" role="alert"></div>
                
                <!-- Скрытое поле для CarId -->
                <input asp-for="CarId" type="hidden" id="selectedCarId" />
                
                <!-- Выбор автомобиля -->
                <div class="car-selector-container">
                    <div class="modern-form-group">
                        <label class="modern-form-label">
                            <i class="bi bi-car-front me-1"></i> Выберите автомобиль
                        </label>
                        <button type="button" class="car-collapsible" id="carCollapsible">
                            <div class="car-collapsible-text" id="carCollapsibleText">-- Выберите автомобиль --</div>
                            <i class="bi bi-chevron-down car-collapsible-icon"></i>
                        </button>
                        <div class="car-content" id="carContent">
                            <div class="car-search-container">
                                <input type="text" 
                                       class="car-search-input" 
                                       id="carSearchInput"
                                       placeholder="Поиск по марке, модели или номеру..." />
                            </div>
                            <div class="car-options-list" id="carOptionsList">
                                <!-- Через JavaScript -->
                            </div>
                        </div>
                        <span asp-validation-for="CarId" class="validation-error"></span>
                    </div>
                </div>

                <!-- Остальные поля формы -->
                <div class="row">
                    <div class="col-md-6">
                        <div class="modern-form-group">
                            <label asp-for="OrderDate" class="modern-form-label">
                                <i class="bi bi-calendar me-1"></i> Дата заказа
                            </label>
                            <div class="calendar-container">
                                <input asp-for="OrderDate" class="modern-form-input calendar-input" type="text" readonly placeholder="Выберите дату заказа" />
                                <div class="calendar-popup" id="orderDateCalendar">
                                    <div class="calendar-header">
                                        <button type="button" class="calendar-nav-btn" id="orderPrevMonth">
                                            <i class="bi bi-chevron-left"></i>
                                        </button>
                                        <h3 class="calendar-month-year" id="orderMonthYear"></h3>
                                        <button type="button" class="calendar-nav-btn" id="orderNextMonth">
                                            <i class="bi bi-chevron-right"></i>
                                        </button>
                                    </div>
                                    <div class="calendar-weekdays">
                                        <div class="calendar-weekday">Вс</div>
                                        <div class="calendar-weekday">Пн</div>
                                        <div class="calendar-weekday">Вт</div>
                                        <div class="calendar-weekday">Ср</div>
                                        <div class="calendar-weekday">Чт</div>
                                        <div class="calendar-weekday">Пт</div>
                                        <div class="calendar-weekday">Сб</div>
                                    </div>
                                    <div class="calendar-grid" id="orderCalendarGrid"></div>
                                    <div class="calendar-time-section">
                                        <div class="calendar-time-label">Время:</div>
                                        <div class="calendar-time-inputs">
                                            <input type="number" class="calendar-time-input" id="orderHours" min="0" max="23" value="12" />
                                            <span class="calendar-time-separator">:</span>
                                            <input type="number" class="calendar-time-input" id="orderMinutes" min="0" max="59" value="00" />
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <span asp-validation-for="OrderDate" class="validation-error"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="modern-form-group">
                            <label asp-for="PaymentDate" class="modern-form-label">
                                <i class="bi bi-credit-card me-1"></i> Дата оплаты
                            </label>
                            <div class="calendar-container">
                                <input asp-for="PaymentDate" class="modern-form-input calendar-input" type="text" readonly placeholder="Выберите дату оплаты" />
                                <div class="calendar-popup" id="paymentDateCalendar">
                                    <div class="calendar-header">
                                        <button type="button" class="calendar-nav-btn" id="paymentPrevMonth">
                                            <i class="bi bi-chevron-left"></i>
                                        </button>
                                        <h3 class="calendar-month-year" id="paymentMonthYear"></h3>
                                        <button type="button" class="calendar-nav-btn" id="paymentNextMonth">
                                            <i class="bi bi-chevron-right"></i>
                                        </button>
                                    </div>
                                    <div class="calendar-weekdays">
                                        <div class="calendar-weekday">Вс</div>
                                        <div class="calendar-weekday">Пн</div>
                                        <div class="calendar-weekday">Вт</div>
                                        <div class="calendar-weekday">Ср</div>
                                        <div class="calendar-weekday">Чт</div>
                                        <div class="calendar-weekday">Пт</div>
                                        <div class="calendar-weekday">Сб</div>
                                    </div>
                                    <div class="calendar-grid" id="paymentCalendarGrid"></div>
                                    <div class="calendar-time-section">
                                        <div class="calendar-time-label">Время:</div>
                                        <div class="calendar-time-inputs">
                                            <input type="number" class="calendar-time-input" id="paymentHours" min="0" max="23" value="12" />
                                            <span class="calendar-time-separator">:</span>
                                            <input type="number" class="calendar-time-input" id="paymentMinutes" min="0" max="59" value="00" />
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <span asp-validation-for="PaymentDate" class="validation-error"></span>
                        </div>
                    </div>
                </div>

                <div class="modern-form-group">
                    <label asp-for="MasterId" class="modern-form-label">
                        <i class="bi bi-person-badge me-1"></i> Ответственный мастер
                    </label>
                    <select asp-for="MasterId" class="modern-form-select" asp-items="ViewBag.MasterId">
                        <option value="">-- Выберите мастера (не обязательно) --</option>
                    </select>
                    <span asp-validation-for="MasterId" class="validation-error"></span>
                    <div class="form-text-helper">Если оставить пустым, мастер будет назначен позже</div>
                </div>
                
                <!-- Услуги -->
                <div class="modern-form-group">
                    <label class="modern-form-label"><i class="bi bi-tools me-1"></i> Услуги</label>
                    <div class="d-flex gap-2 mb-2">
                        <select id="serviceSelect" class="modern-form-select" style="flex:2;">
                            <option value="">-- Выберите услугу --</option>
                            @foreach (var s in (List<TyreServiceApp.Models.Service>)ViewBag.Services)
                            {
                                <option value="@s.ServiceCode">@s.ServiceName (@s.ServiceCost.ToString("C2"))</option>
                            }
                        </select>
                        <input type="number" id="wheelCount" class="modern-form-input" style="flex:0 0 80px;" min="0" max="4" value="4" placeholder="Колёса" />
                        <button type="button" class="btn btn-dark" id="addServiceBtn" style="flex:0 0 auto;">+</button>
                    </div>
                    <table class="table table-sm mb-0" id="servicesTable">
                        <thead><tr><th>Услуга</th><th>Колёс</th><th></th></tr></thead>
                        <tbody id="servicesList"></tbody>
                    </table>
                </div>

                <!-- Коэффициенты сложности -->
                <div class="modern-form-group">
                    <label class="modern-form-label"><i class="bi bi-sliders me-1"></i> Коэффициенты сложности</label>
                    <div id="complexityCheckboxes" class="d-flex flex-wrap gap-3">
                        @foreach (var cc in (List<TyreServiceApp.Models.ComplexityCoefficient>)ViewBag.ComplexityCoefficients)
                        {
                            <label class="d-flex align-items-center gap-1" style="font-size:13px;cursor:pointer;">
                                <input type="checkbox" class="complexity-cb" value="@cc.ComplexityCoefficientId" />
                                @cc.Name (×@cc.Factor)
                            </label>
                        }
                    </div>
                </div>

                <!-- Расходники -->
                <div class="modern-form-group">
                    <label class="modern-form-label"><i class="bi bi-box-seam me-1"></i> Расходники</label>
                    <div class="d-flex gap-2 mb-2">
                        <select id="consumableSelect" class="modern-form-select" style="flex:2;">
                            <option value="">-- Выберите расходник --</option>
                            @foreach (var c in (List<TyreServiceApp.Models.Consumable>)ViewBag.Consumables)
                            {
                                <option value="@c.ConsumableId" data-sell="@c.SellPrice">@c.Name (@c.SellPrice.ToString("C2"))</option>
                            }
                        </select>
                        <input type="number" id="consumableQty" class="modern-form-input" style="flex:0 0 80px;" min="1" value="1" />
                        <button type="button" class="btn btn-dark" id="addConsumableBtn" style="flex:0 0 auto;">+</button>
                    </div>
                    <table class="table table-sm mb-0" id="consumablesTable">
                        <thead><tr><th>Расходник</th><th>Кол-во</th><th></th></tr></thead>
                        <tbody id="consumablesList"></tbody>
                    </table>
                </div>

                <!-- Скидка -->
                <div class="modern-form-group">
                    <label class="modern-form-label"><i class="bi bi-percent me-1"></i> Скидка</label>
                    <div class="d-flex gap-2 align-items-center">
                        <input type="number" id="discountPercent" class="modern-form-input" style="flex:0 0 80px;" min="0" max="100" value="0" placeholder="%" />
                        <select id="discountType" class="modern-form-select" style="flex:1;">
                            <option value="soft">Мягкая (за счёт владельца)</option>
                            <option value="hard">Жёсткая (мастера)</option>
                        </select>
                        <span style="font-size:13px;color:#64748b;">Мастеров на посту: <input type="number" id="masterCount" class="modern-form-input" style="width:60px;display:inline-block;" min="1" value="1" /></span>
                    </div>
                </div>

                <!-- Результат -->
                <div class="modern-form-group" id="resultSection" style="display:none;">
                    <label class="modern-form-label"><i class="bi bi-calculator me-1"></i> Предварительный расчёт</label>
                    <div class="card border-0 bg-light p-3">
                        <table class="table table-sm mb-0">
                            <thead><tr><th>Услуга</th><th>База</th><th>Коэфф.</th><th>Клиент</th><th>Мастер</th></tr></thead>
                            <tbody id="resultItems"></tbody>
                        </table>
                        <hr />
                        <div class="d-flex justify-content-between fw-bold">
                            <span>Клиент: <span id="resultClientTotal">0</span> ₽</span>
                            <span>ФОТ: <span id="resultMasterShare">0</span> ₽</span>
                            <span>На мастера: <span id="resultPerMaster">0</span> ₽</span>
                        </div>
                    </div>
                </div>

                <!-- Скрытые поля для передачи данных -->
                <input type="hidden" name="serviceItems" id="serviceItemsHidden" />
                <input type="hidden" name="complexityIds" id="complexityIdsHidden" />
                <input type="hidden" name="consumableItems" id="consumableItemsHidden" />

                <!-- Кнопки действий -->
                <div class="d-flex gap-2 mt-4 pt-2">
                    <button type="button" class="btn btn-outline-dark px-4" id="calculateBtn">
                        <i class="bi bi-calculator"></i> Рассчитать
                    </button>
                    <button type="submit" class="btn btn-dark px-4">
                        <i class="bi bi-check-lg"></i> Сохранить
                    </button>
                    <a asp-area="" asp-controller="Orders" asp-action="Index" class="btn btn-outline-secondary px-4">
                        <i class="bi bi-x-lg"></i> Отмена
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Данные автомобилей
        var carsData = @Html.Raw(Json.Serialize(ViewBag.CarsData));
        
        // Элементы DOM
        const carCollapsible = document.getElementById('carCollapsible');
        const carContent = document.getElementById('carContent');
        const carCollapsibleText = document.getElementById('carCollapsibleText');
        const carSearchInput = document.getElementById('carSearchInput');
        const carOptionsList = document.getElementById('carOptionsList');
        const selectedCarIdInput = document.getElementById('selectedCarId');
        
        let isOpen = false;
        let selectedCarId = null;
        
        // Инициализация
        document.addEventListener('DOMContentLoaded', function() {
            renderCarOptions(carsData);
        });
        
        carCollapsible.addEventListener('click', function() {
            if (isOpen) {
                closeCarSelector();
            } else {
                openCarSelector();
            }
        });
        
        // Обработчик поиска
        carSearchInput.addEventListener('input', function() {
            const searchTerm = this.value.toLowerCase();
            const filteredCars = carsData.filter(car => 
                car.brand.toLowerCase().includes(searchTerm) ||
                car.model.toLowerCase().includes(searchTerm) ||
                car.licensePlate.toLowerCase().includes(searchTerm) ||
                car.clientName.toLowerCase().includes(searchTerm)
            );
            renderCarOptions(filteredCars);
        });
        
        function openCarSelector() {
            isOpen = true;
            carCollapsible.classList.add('active');
            carContent.classList.add('active');
            carContent.style.maxHeight = carContent.scrollHeight + "px";
            
            // Фокус на поле поиска
            setTimeout(() => {
                carSearchInput.focus();
            }, 100);
        }
        
        function closeCarSelector() {
            isOpen = false;
            carCollapsible.classList.remove('active');
            carContent.classList.remove('active');
            carContent.style.maxHeight = null;
        }
        
        function renderCarOptions(cars) {
            carOptionsList.innerHTML = '';
            
            if (cars.length === 0) {
                carOptionsList.innerHTML = '<div class="car-option" style="cursor: default; color: #6c757d;">Автомобили не найдены</div>';
                return;
            }
            
            cars.forEach(car => {
                const option = document.createElement('div');
                option.className = 'car-option';
                if (selectedCarId === car.carId) {
                    option.classList.add('selected');
                }
                
                option.innerHTML = `
                    <div class="car-option-photo-container">
                        ${car.photoPath && car.photoPath.length > 0 ? 
                            `<img src="${car.photoPath}" class="car-option-photo" alt="Car photo" />` :
                            `<div class="car-option-placeholder"><i class="bi bi-car-front"></i></div>`
                        }
                    </div>
                    <div class="car-option-info">
                        <div class="car-option-title">${car.brand} ${car.model}</div>
                        <div class="car-option-details">${car.licensePlate} | ${car.clientName}</div>
                    </div>
                `;
                
                option.addEventListener('click', function() {
                    selectCar(car);
                });
                
                carOptionsList.appendChild(option);
            });
        }
        
        function selectCar(car) {
            selectedCarId = car.carId;
            selectedCarIdInput.value = car.carId;
            
            const photoHtml = car.photoPath && car.photoPath.length > 0 ? 
                `<img src="${car.photoPath}" class="selected-car-photo" alt="Car" />` : '';
            
            carCollapsibleText.innerHTML = `
                <div class="selected-car-display">
                    ${photoHtml}
                    <span>${car.brand} ${car.model} (${car.licensePlate})</span>
                </div>
            `;
            
            document.querySelectorAll('.car-option').forEach(option => {
                option.classList.remove('selected');
            });
            event.currentTarget.classList.add('selected');
            
            closeCarSelector();
        }
        
        document.addEventListener('click', function(event) {
            if (!carCollapsible.contains(event.target) && !carContent.contains(event.target)) {
                closeCarSelector();
            }
        });

        // Календарь скрипт
        const monthNames = ["Январь", "Февраль", "Март", "Апрель", "Май", "Июнь",
            "Июль", "Август", "Сентябрь", "Октябрь", "Ноябрь", "Декабрь"];

        // Инициализация календарей
        initCalendar('order', 'OrderDate');
        initCalendar('payment', 'PaymentDate');

        function initCalendar(prefix, fieldName) {
            const input = document.querySelector(`input[name="${fieldName}"]`);
            const calendar = document.getElementById(`${prefix}DateCalendar`);
            const monthYearEl = document.getElementById(`${prefix}MonthYear`);
            const gridEl = document.getElementById(`${prefix}CalendarGrid`);
            const prevBtn = document.getElementById(`${prefix}PrevMonth`);
            const nextBtn = document.getElementById(`${prefix}NextMonth`);

            if (!input || !calendar || !monthYearEl || !gridEl || !prevBtn || !nextBtn) {
                console.error('Calendar elements not found for:', prefix);
                return;
            }

            let currentDate = new Date();
            let selectedDate = null;

            // Показать/скрыть календарь
            input.addEventListener('click', function() {
                const allCalendars = document.querySelectorAll('.calendar-popup');
                allCalendars.forEach(cal => {
                    if (cal !== calendar) {
                        cal.classList.remove('active');
                    }
                });
                calendar.classList.toggle('active');
            });

            // Навигация по месяцам
            prevBtn.addEventListener('click', function() {
                currentDate.setMonth(currentDate.getMonth() - 1);
                renderCalendar();
            });

            nextBtn.addEventListener('click', function() {
                currentDate.setMonth(currentDate.getMonth() + 1);
                renderCalendar();
            });

            function renderCalendar() {
                const year = currentDate.getFullYear();
                const month = currentDate.getMonth();

                monthYearEl.textContent = `${monthNames[month]} ${year}`;

                const firstDay = new Date(year, month, 1).getDay();
                const daysInMonth = new Date(year, month + 1, 0).getDate();

                const today = new Date();
                const isCurrentMonth = today.getMonth() === month && today.getFullYear() === year;

                gridEl.innerHTML = '';

                // Пустые ячейки для дней до первого дня месяца
                for (let i = 0; i < firstDay; i++) {
                    const emptyCell = document.createElement('div');
                    emptyCell.className = 'calendar-day empty';
                    gridEl.appendChild(emptyCell);
                }

                // Дни месяца
                for (let day = 1; day <= daysInMonth; day++) {
                    const dayCell = document.createElement('button');
                    dayCell.type = 'button';
                    dayCell.textContent = day;

                    let classes = 'calendar-day ';

                    const isToday = isCurrentMonth && today.getDate() === day;
                    const isSelected = selectedDate &&
                        selectedDate.getDate() === day &&
                        selectedDate.getMonth() === month &&
                        selectedDate.getFullYear() === year;

                    if (isSelected) {
                        classes += 'selected';
                    } else if (isToday) {
                        classes += 'today';
                    }

                    dayCell.className = classes;
                    dayCell.addEventListener('click', () => selectDate(year, month, day));
                    gridEl.appendChild(dayCell);
                }
            }

            function selectDate(year, month, day) {
                selectedDate = new Date(year, month, day);
                
                const hoursInput = document.getElementById(`${prefix}Hours`);
                const minutesInput = document.getElementById(`${prefix}Minutes`);
                
                const hours = parseInt(hoursInput.value) || 0;
                const minutes = parseInt(minutesInput.value) || 0;
                
                selectedDate.setHours(hours, minutes, 0, 0);
                
                const formattedDate = selectedDate.toLocaleDateString('ru-RU');
                const formattedTime = `${hours.toString().padStart(2, '0')}:${minutes.toString().padStart(2, '0')}`;
                input.value = `${formattedDate} ${formattedTime}`;

                const pad = (n) => String(n).padStart(2, '0');
                const localIso = `${selectedDate.getFullYear()}-${pad(selectedDate.getMonth()+1)}-${pad(selectedDate.getDate())}T${pad(selectedDate.getHours())}:${pad(selectedDate.getMinutes())}`;
                input.setAttribute('data-value', localIso);

                renderCalendar();
                calendar.classList.remove('active');
            }

            // Обработчики изменения времени
            const hoursInput = document.getElementById(`${prefix}Hours`);
            const minutesInput = document.getElementById(`${prefix}Minutes`);
            
            if (hoursInput && minutesInput) {
                hoursInput.addEventListener('input', function() {
                    let value = parseInt(this.value);
                    if (value > 23) this.value = 23;
                    if (value < 0) this.value = 0;
                });
                
                minutesInput.addEventListener('input', function() {
                    let value = parseInt(this.value);
                    if (value > 59) this.value = 59;
                    if (value < 0) this.value = 0;
                });
            }

            // Закрытие при клике вне календаря
            document.addEventListener('click', function(event) {
                if (!calendar.contains(event.target) && !input.contains(event.target)) {
                    calendar.classList.remove('active');
                }
            });

            // Инициализация
            renderCalendar();
        }

        // Конвертация даты в правильный формат
        document.querySelector('form').addEventListener('submit', function() {
            const orderDateInput = document.querySelector('input[name="OrderDate"]');
            const paymentDateInput = document.querySelector('input[name="PaymentDate"]');

            if (orderDateInput.getAttribute('data-value')) {
                orderDateInput.value = orderDateInput.getAttribute('data-value');
            }
            if (paymentDateInput.getAttribute('data-value')) {
                paymentDateInput.value = paymentDateInput.getAttribute('data-value');
            }

            // Сериализовать данные перед отправкой
            serializeCalculationData();
        });

        // ---- Расчёт ---- //
        var addedServices = [];
        var addedConsumables = [];

        var costDisplay = document.createElement('span');
        costDisplay.id = 'costPreview';
        costDisplay.className = 'ms-2 text-muted small fw-medium';
        document.getElementById('wheelCount').after(costDisplay);

        function calculateTotal() {
            var select = document.getElementById('serviceSelect');
            var wheelInput = document.getElementById('wheelCount');
            var serviceCode = parseInt(select.value);
            if (!serviceCode) { costDisplay.textContent = ''; return; }
            var wheelCount = parseInt(wheelInput.value) || 1;
            fetch('/api/orders/preview', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    carClassId: getSelectedCarClassId(),
                    items: [{ serviceCode: serviceCode, wheelCount: wheelCount }]
                })
            })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                var cost = data.clientTotal || 0;
                costDisplay.textContent = '= ' + cost.toFixed(2) + ' ₽';
            })
            .catch(function() { costDisplay.textContent = '—'; });
        }

        document.getElementById('serviceSelect').addEventListener('change', calculateTotal);
        document.getElementById('wheelCount').addEventListener('input', calculateTotal);
        document.getElementById('addServiceBtn').addEventListener('click', function() {
            var select = document.getElementById('serviceSelect');
            var wheelInput = document.getElementById('wheelCount');
            var serviceCode = parseInt(select.value);
            if (!serviceCode) return;
            var serviceName = select.options[select.selectedIndex].text;
            var wheelCount = parseInt(wheelInput.value) || 1;
            addedServices.push({ serviceCode: serviceCode, serviceName: serviceName, wheelCount: wheelCount });
            renderServices();
            select.value = '';
            wheelInput.value = 4;
        });

        function renderServices() {
            var tbody = document.getElementById('servicesList');
            tbody.innerHTML = '';
            addedServices.forEach(function(s, i) {
                var tr = document.createElement('tr');
                tr.innerHTML = '<td>' + s.serviceName + '</td><td>' + s.wheelCount + '</td>' +
                    '<td><button type="button" class="btn btn-sm btn-outline-danger" onclick="addedServices.splice(' + i + ',1);renderServices();">✕</button></td>';
                tbody.appendChild(tr);
            });
        }

        document.getElementById('addConsumableBtn').addEventListener('click', function() {
            var select = document.getElementById('consumableSelect');
            var qtyInput = document.getElementById('consumableQty');
            var consumableId = parseInt(select.value);
            if (!consumableId) return;
            var consumableName = select.options[select.selectedIndex].text;
            var quantity = parseInt(qtyInput.value) || 1;
            addedConsumables.push({ consumableId: consumableId, consumableName: consumableName, quantity: quantity });
            renderConsumables();
            select.value = '';
            qtyInput.value = 1;
        });

        function renderConsumables() {
            var tbody = document.getElementById('consumablesList');
            tbody.innerHTML = '';
            addedConsumables.forEach(function(c, i) {
                var tr = document.createElement('tr');
                tr.innerHTML = '<td>' + c.consumableName + '</td><td>' + c.quantity + '</td>' +
                    '<td><button type="button" class="btn btn-sm btn-outline-danger" onclick="addedConsumables.splice(' + i + ',1);renderConsumables();">✕</button></td>';
                tbody.appendChild(tr);
            });
        }

        function getSelectedCarClassId() {
            if (!selectedCarId) return null;
            var car = carsData.find(function(c) { return c.carId === selectedCarId; });
            return car ? car.carClassId : null;
        }

        document.getElementById('calculateBtn').addEventListener('click', function() {
            if (addedServices.length === 0) { alert('Добавьте хотя бы одну услугу'); return; }

            var carClassId = getSelectedCarClassId();
            var complexityIds = Array.from(document.querySelectorAll('.complexity-cb:checked')).map(function(cb) { return parseInt(cb.value); });
            var consumables = addedConsumables.map(function(c) { return { consumableId: c.consumableId, quantity: c.quantity }; });
            var discountPercent = parseFloat(document.getElementById('discountPercent').value) || 0;
            var discountType = document.getElementById('discountType').value;
            var masterCount = parseInt(document.getElementById('masterCount').value) || 1;

            fetch('/api/orders/preview', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    carClassId: carClassId,
                    items: addedServices.map(function(s) { return { serviceCode: s.serviceCode, wheelCount: s.wheelCount }; }),
                    complexityCoefficientIds: complexityIds,
                    consumables: consumables,
                    discountPercent: discountPercent,
                    discountType: discountType,
                    masterCount: masterCount
                })
            })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                var section = document.getElementById('resultSection');
                section.style.display = 'block';

                var tbody = document.getElementById('resultItems');
                tbody.innerHTML = '';
                data.items.forEach(function(item) {
                    var tr = document.createElement('tr');
                    tr.innerHTML = '<td>Услуга #' + item.serviceCode + '</td>' +
                        '<td>' + item.basePrice.toFixed(2) + '</td>' +
                        '<td>×' + item.complexitySum.toFixed(2) + '</td>' +
                        '<td>' + item.workTotal.toFixed(2) + '</td>' +
                        '<td>' + item.masterShare.toFixed(2) + '</td>';
                    tbody.appendChild(tr);
                });

                document.getElementById('resultClientTotal').textContent = data.clientTotal.toFixed(2);
                document.getElementById('resultMasterShare').textContent = data.masterShare.toFixed(2);
                document.getElementById('resultPerMaster').textContent = data.masterPerMaster.toFixed(2);
            })
            .catch(function() {
                alert('Ошибка расчёта');
            });
        });

        function serializeCalculationData() {
            document.getElementById('serviceItemsHidden').value = JSON.stringify(addedServices.map(function(s) {
                return { serviceCode: s.serviceCode, wheelCount: s.wheelCount };
            }));
            document.getElementById('complexityIdsHidden').value = JSON.stringify(
                Array.from(document.querySelectorAll('.complexity-cb:checked')).map(function(cb) { return parseInt(cb.value); })
            );
            document.getElementById('consumableItemsHidden').value = JSON.stringify(addedConsumables.map(function(c) {
                return { consumableId: c.consumableId, quantity: c.quantity };
            }));
        }
    </script>
}