@model TyreServiceApp.Models.CustomerReview

@{
    ViewData["Title"] = "Удалить отзыв";
}

<partial name="_FormStyles" />
<style>
    .details-row { display:flex; align-items:center; padding:12px 0; border-bottom:1px solid #f1f5f9; }
    .details-row:last-child { border-bottom:none; }
    .details-label { font-weight:600; color:#64748b; font-size:14px; min-width:120px; display:flex; align-items:center; gap:8px; }
    .details-value { font-weight:500; color:#1e293b; font-size:16px; }
    .review-text { background:#f8f9fa; padding:16px; border-radius:8px; font-size:15px; line-height:1.6; white-space:pre-wrap; }
</style>

<div class="container-fluid pt-2 pb-4">
    <div class="main-3d-wrapper" style="--mw: 600px; --button_outline_color: #dc2626">
        <div class="main-3d-inner">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h3 class="fw-bold m-0">
                    <i class="bi bi-exclamation-triangle me-2"></i> Удаление отзыва
                </h3>
            </div>

            <div class="warning-alert" style="background:#fef3c7;border:2px solid #f59e0b;border-radius:8px;padding:16px;margin-bottom:24px;display:flex;align-items:center;gap:12px;">
                <i class="bi bi-exclamation-triangle-fill" style="color:#d97706;font-size:20px;flex-shrink:0;"></i>
                <div style="color:#92400e;font-weight:500;font-size:14px;">
                    <strong>Внимание!</strong> Вы уверены, что хотите удалить этот отзыв? Это действие нельзя отменить.
                </div>
            </div>

            <div class="mb-4">
                <div class="details-row">
                    <div class="details-label"><i class="bi bi-person"></i> Клиент:</div>
                    <div class="details-value">@(Model.Customer?.Client?.FullName ?? Model.Customer?.Phone ?? "—")</div>
                </div>
                <div class="details-row">
                    <div class="details-label"><i class="bi bi-star"></i> Рейтинг:</div>
                    <div class="details-value">@Model.Rating / 5</div>
                </div>
                <div class="details-row">
                    <div class="details-label"><i class="bi bi-car-front"></i> Автомобиль:</div>
                    <div class="details-value">@(Model.CarModel ?? "—")</div>
                </div>
                <div class="details-row">
                    <div class="details-label"><i class="bi bi-calendar"></i> Дата:</div>
                    <div class="details-value">@Model.CreatedAt.ToString("dd.MM.yyyy")</div>
                </div>
                <div class="mt-4">
                    <div class="details-label mb-2"><i class="bi bi-chat-quote"></i> Текст отзыва:</div>
                    <div class="review-text">@Model.Text</div>
                </div>
            </div>

            <form asp-action="Delete" class="d-flex gap-3 mt-4">
                <input type="hidden" asp-for="ReviewId" />
                <button type="submit" class="btn btn-danger">
                    <i class="bi bi-trash"></i> Удалить
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left"></i> Отмена
                </a>
            </form>
        </div>
    </div>
</div>
