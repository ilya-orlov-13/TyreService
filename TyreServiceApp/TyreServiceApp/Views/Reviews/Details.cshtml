@model TyreServiceApp.Models.CustomerReview

@{
    ViewData["Title"] = "Детали отзыва";
}

<partial name="_FormStyles" />
<style>
    .details-row { display:flex; align-items:center; padding:12px 0; border-bottom:1px solid #f1f5f9; }
    .details-row:last-child { border-bottom:none; }
    .details-label { font-weight:600; color:#64748b; font-size:14px; min-width:120px; display:flex; align-items:center; gap:8px; }
    .details-value { font-weight:500; color:#1e293b; font-size:16px; }
    .review-text { background:#f8f9fa; padding:16px; border-radius:8px; font-size:15px; line-height:1.6; white-space:pre-wrap; }
</style>

<div class="container-fluid pt-2 pb-4">
    <div class="main-3d-wrapper" style="--mw: 600px">
        <div class="main-3d-inner">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h3 class="fw-bold m-0">
                    <i class="bi bi-info-circle me-2"></i> Детали отзыва #@Model.ReviewId
                </h3>
            </div>

            <div class="mb-4">
                <div class="details-row">
                    <div class="details-label"><i class="bi bi-person"></i> Клиент:</div>
                    <div class="details-value">@(Model.Customer?.Client?.FullName ?? Model.Customer?.Phone ?? "—")</div>
                </div>
                <div class="details-row">
                    <div class="details-label"><i class="bi bi-star"></i> Рейтинг:</div>
                    <div class="details-value">
                        @for (int i = 0; i < 5; i++)
                        {
                            <i class="bi @(i < Model.Rating ? "bi-star-fill text-warning" : "bi-star text-muted")"></i>
                        }
                        (@Model.Rating / 5)
                    </div>
                </div>
                <div class="details-row">
                    <div class="details-label"><i class="bi bi-car-front"></i> Автомобиль:</div>
                    <div class="details-value">@(Model.CarModel ?? "—")</div>
                </div>
                <div class="details-row">
                    <div class="details-label"><i class="bi bi-calendar"></i> Дата:</div>
                    <div class="details-value">@Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")</div>
                </div>
                @if (Model.UpdatedAt.HasValue)
                {
                    <div class="details-row">
                        <div class="details-label"><i class="bi bi-pencil"></i> Изменён:</div>
                        <div class="details-value">@Model.UpdatedAt.Value.ToString("dd.MM.yyyy HH:mm")</div>
                    </div>
                }
                <div class="details-row">
                    <div class="details-label"><i class="bi bi-toggle-on"></i> Статус:</div>
                    <div class="details-value">
                        @if (Model.IsApproved)
                        {
                            <span class="badge bg-success">Опубликован</span>
                        }
                        else
                        {
                            <span class="badge bg-warning text-dark">На модерации</span>
                        }
                    </div>
                </div>
                <div class="mt-4">
                    <div class="details-label mb-2"><i class="bi bi-chat-quote"></i> Текст отзыва:</div>
                    <div class="review-text">@Model.Text</div>
                </div>
            </div>

            <div class="d-flex gap-2 mt-4 pt-2">
                @if (!Model.IsApproved)
                {
                    <form asp-action="Approve" asp-route-id="@Model.ReviewId" method="post" style="display:inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-check-lg"></i> Опубликовать
                        </button>
                    </form>
                }
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left"></i> Назад к списку
                </a>
                <a asp-action="Delete" asp-route-id="@Model.ReviewId" class="btn btn-outline-danger ms-auto">
                    <i class="bi bi-trash"></i> Удалить
                </a>
            </div>
        </div>
    </div>
</div>
