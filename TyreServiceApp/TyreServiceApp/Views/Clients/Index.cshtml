@model IEnumerable<TyreServiceApp.Models.Client>

@functions {
    string FormatShortName(string fullName)
    {
        if (string.IsNullOrWhiteSpace(fullName)) return "";
        var parts = fullName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length < 2) return fullName;
        var result = parts[0];
        for (int i = 1; i < parts.Length; i++)
        {
            if (parts[i].Length > 0)
                result += " " + parts[i][0] + ".";
        }
        return result;
    }
}

@{
    ViewData["Title"] = "Клиенты";
}

<partial name="_CardGridStyles" />
<style>
    .clients-grid {
        min-width: 0;
        overflow: hidden;
    }
    .clients-grid > * {
        min-width: 0;
    }

    .add-card-wrapper {
        text-decoration: none;
        display: block;
        height: 100%;
    }

    .add-card {
        min-height: 140px;
        cursor: pointer;
    }

    .client-card-wrapper {
        cursor: pointer;
        height: 100%;
    }

    .client-card {
        width: 100%;
        height: 100%;
        box-sizing: border-box;
        cursor: pointer;
        justify-content: center;
        gap: 14px;
    }

    .client-top-row {
        display: flex;
        align-items: center;
        gap: 14px;
        width: 100%;
    }

    .client-icon-wrapper {
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 60px;
        height: 60px;
        border-radius: 50%;
        background: #f0f0f0;
        color: #888;
    }

    .client-icon-wrapper svg {
        width: 36px;
        height: 36px;
    }

    .client-info {
        flex: 1;
        min-width: 0;
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

    .client-name {
        font-family: 'Montserrat', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        font-weight: 900;
        font-size: clamp(16px, 2vw, 22px);
        line-height: 1.2;
        color: #000000;
        text-align: left;
        user-select: none;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .client-actions {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 16px;
        flex-shrink: 0;
    }

    .client-actions .cars-btn-wrapper {
        flex-shrink: 0;
    }

    .client-actions .delete-btn {
        flex-shrink: 0;
    }

    .client-phone {
        font-size: 13px;
        color: #6c757d;
        display: flex;
        align-items: center;
        gap: 4px;
    }

    .cars-btn {
        flex-shrink: 0;
        background: none;
        border: 1.5px solid #ccc;
        border-radius: 10px;
        padding: 6px 12px;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 5px;
        font-size: 12px;
        font-weight: 700;
        color: #000;
        transition: all 0.2s ease;
        white-space: nowrap;
        text-decoration: none;
        position: relative;
    }

    .cars-btn:hover {
        border-color: #000;
        background: #f5f5f5;
        color: #000;
    }

    .cars-btn-wrapper {
        position: relative;
        flex-shrink: 0;
        align-self: flex-start;
    }

    .cars-btn-wrapper::before {
        content: '';
        position: absolute;
        top: 100%;
        right: 0;
        left: 0;
        height: 8px;
        z-index: 101;
    }

    .cars-dropdown {
        display: none;
        position: absolute;
        top: 100%;
        right: 0;
        margin-top: 6px;
        background: #fff;
        border: 1px solid #ddd;
        border-radius: 12px;
        box-shadow: 0 8px 24px rgba(0,0,0,0.12);
        min-width: 230px;
        z-index: 100;
        overflow: hidden;
    }

    .cars-btn-wrapper:hover .cars-dropdown {
        display: block;
    }

    .cars-dropdown-item {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        padding: 10px 14px;
        text-decoration: none;
        color: #000;
        font-size: 13px;
        font-weight: 600;
        transition: background 0.15s;
    }

    .cars-dropdown-item:hover {
        background: #f0f0f0;
    }

    .cars-dropdown-item:not(:last-child) {
        border-bottom: 1px solid #eee;
    }

    .cars-dropdown-plate {
        font-weight: 400;
        color: #888;
        font-size: 11px;
        flex-shrink: 0;
    }

    .cars-btn .badge-count {
        background: #000;
        color: #fff;
        font-size: 10px;
        font-weight: 800;
        border-radius: 50%;
        width: 18px;
        height: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .delete-btn {
        background: none;
        border: 1.5px solid #ccc;
        border-radius: 10px;
        padding: 8px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s ease;
        color: #999;
    }

    .delete-btn svg {
        width: 16px;
        height: 16px;
    }

    .delete-btn:hover {
        border-color: #dc2626 !important;
        background: #fef2f2 !important;
        color: #dc2626 !important;
    }

    /* Delete modal styles */
    .modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0, 0, 0, 0.5);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 9999;
        opacity: 0;
        transition: opacity 0.3s ease;
    }

    .modal-overlay.modal-show {
        opacity: 1;
    }

    .modal-content {
        background: #fff;
        border-radius: 20px;
        padding: 32px;
        max-width: 420px;
        width: 90%;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
        position: relative;
        transform: translateY(10px);
        transition: transform 0.3s ease;
    }

    .modal-show .modal-content {
        transform: translateY(0);
    }

    .modal-header {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0;
        border: none;
        margin-bottom: 16px;
    }

    .modal-title {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        font-size: 20px;
        font-weight: 700;
        color: #111;
        margin: 0;
    }

    .modal-body {
        padding: 0;
        text-align: center;
        border: none;
    }

    .modal-text {
        font-size: 14px;
        color: #666;
        margin-bottom: 8px;
    }

    .modal-client-info {
        font-size: 16px;
        font-weight: 600;
        color: #111;
        margin-bottom: 4px;
        word-break: break-word;
    }

    .modal-hint {
        font-size: 12px;
        color: #999;
        margin: 0;
    }

    .modal-actions {
        display: flex;
        gap: 10px;
        margin-top: 24px;
    }

    .modal-btn {
        flex: 1;
        padding: 12px;
        border: none;
        border-radius: 12px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
    }

    .modal-btn-cancel {
        background: #f0f0f0;
        color: #333;
    }

    .modal-btn-cancel:hover {
        background: #e0e0e0;
    }

    .modal-btn-delete {
        background: #dc2626;
        color: white;
    }

    .modal-btn-delete:hover {
        background: #b91c1c;
    }

    .trash-icon {
        flex-shrink: 0;
    }

    .cars-count-text {
        font-size: 12px;
        font-weight: 600;
    }

    @@media (max-width: 900px) {
        .clients-grid {
            grid-template-columns: 1fr;
            gap: 12px;
        }

        .client-card {
            padding: 16px 18px;
            border-radius: 14px;
        }

        .client-top-row {
            flex-wrap: wrap;
        }

        .client-icon-wrapper {
            width: 50px;
            height: 50px;
        }

        .client-icon-wrapper svg {
            width: 28px;
            height: 28px;
        }

        .client-name {
            font-size: clamp(14px, 3vw, 18px);
        }

        .client-phone {
            font-size: 12px;
        }

        .cars-dropdown {
            right: auto;
            left: 0;
            min-width: 200px;
        }
    }

    @@media (max-width: 480px) {
        .client-card {
            padding: 14px 14px;
            border-radius: 12px;
            gap: 12px;
        }

        .client-top-row {
            gap: 10px;
            flex-wrap: wrap;
        }

        .client-icon-wrapper {
            width: 44px;
            height: 44px;
        }

        .client-icon-wrapper svg {
            width: 24px;
            height: 24px;
        }

        .client-name {
            font-size: clamp(14px, 4.5vw, 16px);
        }

        .client-phone {
            font-size: 11px;
        }

        .client-actions {
            width: 100%;
            display: flex;
            flex-direction: row;
            justify-content: flex-end;
            gap: 6px;
        }

        .cars-btn {
            padding: 5px 10px;
            font-size: 11px;
        }

        .delete-btn {
            padding: 6px;
        }

        .delete-btn svg {
            width: 14px;
            height: 14px;
        }

        .cars-dropdown {
            right: auto;
            left: 0;
            min-width: 180px;
        }
    }
</style>

<div class="container-fluid pt-2 pb-4">

    @if (Model.Any())
            {
                await Html.RenderPartialAsync("_ViewToggle");

                <div class="view-cards">
                    <div class="clients-grid">
                        @foreach (var client in Model)
                        {
                            <div class="client-card-wrapper" onclick="handleCardClick(event, @client.ClientId)">
                                <div class="client-card">
                                    <div class="client-top-row">
                                        <div class="client-icon-wrapper">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                                                <circle cx="12" cy="7" r="4"></circle>
                                            </svg>
                                        </div>
                                        <div class="client-info">
                                            <div class="client-name">@FormatShortName(client.FullName)</div>
                                            <div class="client-phone">
                                                @if (!string.IsNullOrEmpty(client.Phone))
                                                {
                                                    <i class="bi bi-telephone me-1"></i> @client.Phone
                                                }
                                                else
                                                {
                                                    <span class="text-muted">Нет телефона</span>
                                                }
                                            </div>
                                            <div class="client-phone">
                                                @if (!string.IsNullOrEmpty(client.Email))
                                                {
                                                    <i class="bi bi-envelope me-1"></i> @client.Email
                                                }
                                            </div>
                                        </div>
                                        <div class="client-actions">
                                            @{
                                                var carCount = client.Cars?.Count ?? 0;
                                            }
                                            <div class="cars-btn-wrapper">
                                                <div class="cars-btn" onclick="event.stopPropagation()">
                                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                                        <path d="M5 17h14M5 17l-2-4 1-4h12l2 4-1 4M5 17l1 3h12l1-3M7 10h1M16 10h1"></path>
                                                        <circle cx="7" cy="17" r="1.5"></circle>
                                                        <circle cx="17" cy="17" r="1.5"></circle>
                                                    </svg>
                                                    @if (carCount > 0)
                                                    {
                                                        <span class="badge-count">@carCount</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="cars-count-text">0</span>
                                                    }
                                                </div>
                                                @if (carCount > 0)
                                                {
                                                    <div class="cars-dropdown">
                                                        @foreach (var car in client.Cars)
                                                        {
                                                            <a asp-controller="Cars" asp-action="Details" asp-route-id="@car.CarId" asp-route-returnUrl="/Clients/Index"
                                                               class="cars-dropdown-item" onclick="event.stopPropagation()">
                                                                <span>@car.Brand @car.Model</span>
                                                                <span class="cars-dropdown-plate">@car.LicensePlate</span>
                                                            </a>
                                                        }
                                                    </div>
                                                }
                                            </div>
                                            <button type="button" class="delete-btn" onclick="event.stopPropagation(); showDeleteModal(@client.ClientId, '@client.FullName')" title="Удалить">
                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                    <polyline points="3 6 5 6 21 6"></polyline>
                                                    <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                                                </svg>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                        <a asp-action="Create" class="client-card-wrapper add-card-wrapper">
                            <div class="client-card add-card">
                                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <line x1="12" y1="5" x2="12" y2="19"></line>
                                    <line x1="5" y1="12" x2="19" y2="12"></line>
                                </svg>
                                <span>Добавить клиента</span>
                            </div>
                        </a>
                    </div>
                </div>

                <div class="view-table">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>ФИО</th>
                                <th>Телефон</th>
                                <th>Email</th>
                                <th>Авто</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var client in Model)
                            {
                                <tr onclick="handleCardClick(event, @client.ClientId)" style="cursor:pointer;">
                                    <td data-label="ФИО">@client.FullName</td>
                                    <td data-label="Телефон">@(client.Phone ?? "—")</td>
                                    <td data-label="Email">@(client.Email ?? "—")</td>
                                    <td data-label="Авто">@(client.Cars?.Count ?? 0)</td>
                                    <td data-label="">
                                        <div class="table-actions" onclick="event.stopPropagation()">
                                            <a asp-action="Edit" asp-route-id="@client.ClientId" title="Редактировать">
                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.828 2.828 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5L17 3z"></path></svg>
                                            </a>
                                            <button class="danger" title="Удалить" onclick="showDeleteModal(@client.ClientId, '@client.FullName')">
                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5 border rounded bg-light">
                    <i class="bi bi-people text-muted" style="font-size: 3rem;"></i>
                    <h4 class="mt-3">Клиенты не найдены</h4>
                    <p class="text-muted">Добавьте первого клиента для начала работы.</p>
                    <a asp-action="Create" class="btn btn-dark mt-3"><i class="bi bi-plus-circle me-1"></i> Добавить</a>
                </div>
            }

</div>

<!-- Delete Modal -->
<div id="deleteModal" class="modal-overlay" style="display:none;" onclick="closeDeleteModal(event)">
    <div class="modal-content" onclick="event.stopPropagation()">
        <div class="modal-header">
            <h3 class="modal-title">Удалить клиента?</h3>
        </div>
        <div class="modal-body">
            <p class="modal-text">Вы уверены, что хотите удалить</p>
            <p id="deleteClientInfo" class="modal-client-info"></p>
            <p class="modal-hint">Это действие нельзя отменить.</p>
        </div>
        <form id="deleteForm" method="post" asp-action="Delete" asp-controller="Clients">
            @Html.AntiForgeryToken()
            <input type="hidden" id="deleteClientId" name="id" value="" />
            <div class="modal-actions">
                <button type="button" class="modal-btn modal-btn-cancel" onclick="closeDeleteModal()">Отмена</button>
                <button type="submit" class="modal-btn modal-btn-delete">
                    <svg class="trash-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:16px;height:16px;">
                        <polyline points="3 6 5 6 21 6"></polyline>
                        <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                        <line x1="10" y1="11" x2="10" y2="17"></line>
                        <line x1="14" y1="11" x2="14" y2="17"></line>
                    </svg>
                    Удалить
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function handleCardClick(event, clientId) {
            var target = event.target;
            if (target.closest('.cars-btn-wrapper') || target.closest('.delete-btn')) {
                return;
            }
            location.href = '/Clients/Details/' + clientId;
        }

        function showDeleteModal(clientId, clientName) {
            document.getElementById('deleteClientId').value = clientId;
            document.getElementById('deleteClientInfo').textContent = clientName;
            var modal = document.getElementById('deleteModal');
            modal.style.display = 'flex';
            setTimeout(function() { modal.classList.add('modal-show'); }, 10);
        }

        function closeDeleteModal(e) {
            if (e && e.target !== e.currentTarget) return;
            var modal = document.getElementById('deleteModal');
            modal.classList.remove('modal-show');
            setTimeout(function() { modal.style.display = 'none'; }, 300);
        }
    </script>
}
