@model TyreServiceApp.Models.Client
@{
    ViewData["Title"] = "Подробности о клиенте";
}

<partial name="_FormStyles" />
<style>
    .details-row {
        display: flex;
        align-items: center;
        padding: 12px 0;
        border-bottom: 1px solid #f1f5f9;
    }

    .details-row:last-child {
        border-bottom: none;
    }

    .details-label {
        font-weight: 600;
        color: #64748b;
        font-size: 14px;
        min-width: 120px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .details-value {
        font-weight: 500;
        color: #1e293b;
        font-size: 16px;
    }
</style>

<div class="container-fluid pt-2 pb-4">
    <div class="main-3d-wrapper" style="--mw: 600px">
        <div class="main-3d-inner">
            
            <!-- Заголовок -->
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h3 class="fw-bold m-0">
                    <i class="bi bi-info-circle me-2"></i> Подробности о клиенте
                </h3>
            </div>

            <!-- Детали клиента -->
            <div class="mb-4">
                <div class="details-row">
                    <div class="details-label">
                        <i class="bi bi-person"></i> ФИО:
                    </div>
                    <div class="details-value">
                        @Model.FullName
                    </div>
                </div>
                
                <div class="details-row">
                    <div class="details-label">
                        <i class="bi bi-telephone"></i> Телефон:
                    </div>
                    <div class="details-value">
                        @Model.Phone
                    </div>
                </div>

                <div class="details-row">
                    <div class="details-label">
                        <i class="bi bi-envelope"></i> Email:
                    </div>
                    <div class="details-value">
                        @(!string.IsNullOrEmpty(Model.Email) ? Model.Email : "—")
                    </div>
                </div>
            </div>

            <!-- Кнопки действий -->
            <div class="d-flex gap-3 mt-4">
                <a asp-action="Edit" asp-route-id="@Model.ClientId" class="modern-btn modern-btn-primary">
                    <i class="bi bi-pencil"></i> Редактировать
                </a>
                @{
                    var returnUrl = Context.Request.Query["returnUrl"].FirstOrDefault();
                }
                <a href="@(returnUrl ?? Url.Action("Index"))" class="modern-btn modern-btn-secondary">
                    <i class="bi bi-arrow-left"></i> Вернуться к списку
                </a>
            </div>

        </div>
    </div>
</div>