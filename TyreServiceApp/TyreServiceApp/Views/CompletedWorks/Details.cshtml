@model TyreServiceApp.Models.CompletedWork
@{
    ViewData["Title"] = "Подробности о выполненной работе";
}

<partial name="_FormStyles" />
<style>
    .details-row {
        display: flex;
        align-items: center;
        padding: 12px 0;
        border-bottom: 1px solid #f1f5f9;
    }

    .details-row:last-child {
        border-bottom: none;
    }

    .details-label {
        font-weight: 600;
        color: #64748b;
        font-size: 14px;
        min-width: 180px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .details-value {
        font-weight: 500;
        color: #1e293b;
        font-size: 16px;
    }

    .order-badge {
        background-color: #f8fafc;
        color: #334155;
        padding: 6px 12px;
        border-radius: 6px;
        font-weight: 600;
        border: 1px solid #e9d5ff;
        font-family: monospace;
    }

    .wheel-badge {
        background-color: #f8fafc;
        color: #334155;
        padding: 6px 12px;
        border-radius: 6px;
        font-weight: 600;
        border: 1px solid #e9d5ff;
    }

    .time-badge {
        background-color: #f8fafc;
        color: #334155;
        padding: 6px 12px;
        border-radius: 6px;
        font-weight: 600;
        border: 1px solid #e9d5ff;
    }

    .cost-badge {
        background-color: #f8fafc;
        color: #334155;
        padding: 8px 16px;
        border-radius: 8px;
        font-weight: 700;
        border: 1px solid #e9d5ff;
        font-size: 18px;
    }

    .service-info {
        background-color: #f8fafc;
        color: #334155;
        padding: 8px 12px;
        border-radius: 6px;
        font-weight: 500;
        border: 1px solid #e9d5ff;
    }

    .master-info {
        background-color: #f8fafc;
        color: #334155;
        padding: 8px 12px;
        border-radius: 6px;
        font-weight: 500;
        border: 1px solid #e9d5ff;
    }
</style>

<div class="container-fluid pt-2 pb-4">
    <div class="main-3d-wrapper">
        <div class="main-3d-inner">
            
            <!-- Заголовок -->
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h3 class="fw-bold m-0">
                    <i class="bi bi-info-circle me-2"></i> Подробности о выполненной работе
                </h3>
            </div>

            <!-- Детали выполненной работы -->
            <div class="mb-4">
                <div class="details-row">
                    <div class="details-label">
                        <i class="bi bi-receipt"></i> Номер заказа:
                    </div>
                    <div class="details-value">
                        <span class="order-badge">@Model.OrderNumber</span>
                    </div>
                </div>
                
                <div class="details-row">
                    <div class="details-label">
                        <i class="bi bi-gear"></i> Услуга:
                    </div>
                    <div class="details-value">
                        @if (Model.Service != null)
                        {
                            <span class="service-info">@Model.Service.ServiceName</span>
                        }
                        else
                        {
                            <span class="text-muted">Не указана</span>
                        }
                    </div>
                </div>
                
                <div class="details-row">
                    <div class="details-label">
                        <i class="bi bi-person-badge"></i> Мастер:
                    </div>
                    <div class="details-value">
                        @if (Model.Master != null)
                        {
                            <span class="master-info">@Model.Master.FullName</span>
                        }
                        else
                        {
                            <span class="text-muted">Не указан</span>
                        }
                    </div>
                </div>
                
                <div class="details-row">
                    <div class="details-label">
                        <i class="bi bi-circle"></i> Количество колес:
                    </div>
                    <div class="details-value">
                        <span class="wheel-badge">@Model.WheelCount</span>
                    </div>
                </div>
                
                <div class="details-row">
                    <div class="details-label">
                        <i class="bi bi-clock"></i> Время выполнения:
                    </div>
                    <div class="details-value">
                        <span class="time-badge">@Model.CompletionTimeMin мин</span>
                    </div>
                </div>
                
                <div class="details-row">
                    <div class="details-label">
                        <i class="bi bi-currency-exchange"></i> Итоговая стоимость:
                    </div>
                    <div class="details-value">
                        <span class="cost-badge">@Model.WorkTotal ₽</span>
                    </div>
                </div>
            </div>

            <!-- Кнопки действий -->
            <div class="d-flex gap-3 mt-4">
                <a asp-action="Edit" asp-route-id="@Model.WorkId" class="modern-btn modern-btn-primary">
                    <i class="bi bi-pencil"></i> Редактировать
                </a>
                <a asp-action="Index" class="modern-btn modern-btn-secondary">
                    <i class="bi bi-arrow-left"></i> Вернуться к списку
                </a>
            </div>

        </div>
    </div>
</div>