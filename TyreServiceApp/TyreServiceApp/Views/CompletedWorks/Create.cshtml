@model TyreServiceApp.Models.CompletedWork

@{
    ViewData["Title"] = "Добавить выполненную работу";
}

<partial name="_FormStyles" />

<div class="container-fluid pt-2 pb-4">
    <div class="main-3d-wrapper" style="--mw: 800px">
        <div class="main-3d-inner">
            
            <!-- Заголовок -->
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h3 class="fw-bold m-0">
                    Добавить выполненную работу
                </h3>
            </div>

            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="alert-danger" role="alert"></div>
                
                <div class="row">
                    <div class="col-md-4">
                        <div class="modern-form-group">
                            <label asp-for="OrderNumber" class="modern-form-label">
                                <i class="bi bi-receipt me-1"></i> Номер заказа
                            </label>
                            <select asp-for="OrderNumber" class="modern-form-select" asp-items="ViewBag.OrderNumber">
                                <option value="">-- Выберите заказ --</option>
                            </select>
                            <span asp-validation-for="OrderNumber" class="validation-error"></span>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="modern-form-group">
                            <label asp-for="ServiceCode" class="modern-form-label">
                                <i class="bi bi-gear me-1"></i> Услуга
                            </label>
                            <select asp-for="ServiceCode" class="modern-form-select" asp-items="ViewBag.ServiceCode">
                                <option value="">-- Выберите услугу --</option>
                            </select>
                            <span asp-validation-for="ServiceCode" class="validation-error"></span>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="modern-form-group">
                            <label asp-for="MasterId" class="modern-form-label">
                                <i class="bi bi-person-badge me-1"></i> Мастер
                            </label>
                            <select asp-for="MasterId" class="modern-form-select" asp-items="ViewBag.MasterId">
                                <option value="">-- Выберите мастера --</option>
                            </select>
                            <span asp-validation-for="MasterId" class="validation-error"></span>
                        </div>
                    </div>
                </div>
                
                <div class="row">
                    <div class="col-md-4">
                        <div class="modern-form-group">
                            <label asp-for="WheelCount" class="modern-form-label">
                                <i class="bi bi-circle me-1"></i> Количество колес
                            </label>
                            <input asp-for="WheelCount" class="modern-form-input" type="number" placeholder="1-4" />
                            <span asp-validation-for="WheelCount" class="validation-error"></span>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="modern-form-group">
                            <label asp-for="CompletionTimeMin" class="modern-form-label">
                                <i class="bi bi-clock me-1"></i> Время выполнения (мин)
                            </label>
                            <input asp-for="CompletionTimeMin" class="modern-form-input" type="number" placeholder="Минуты" />
                            <span asp-validation-for="CompletionTimeMin" class="validation-error"></span>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="modern-form-group">
                            <label asp-for="WorkTotal" class="modern-form-label">
                                <i class="bi bi-currency-exchange me-1"></i> Итоговая стоимость
                            </label>
                            <input asp-for="WorkTotal" class="modern-form-input" type="number" step="0.01" placeholder="0.00" />
                            <span asp-validation-for="WorkTotal" class="validation-error"></span>
                        </div>
                    </div>
                </div>
                
                <!-- Кнопки действий -->
                <div class="d-flex gap-2 mt-4 pt-2">
                    <button type="submit" class="btn btn-dark px-4">
                        <i class="bi bi-check-lg"></i> Сохранить изменения
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary px-4">
                        <i class="bi bi-x-lg"></i> Отмена
                    </a>
                </div>
            </form>

        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    <script>
        $(document).ready(function() {
            // Функция для расчета итоговой стоимости
            function calculateTotal() {
                var serviceCode = $('#ServiceCode').val();
                var wheelCount = $('#WheelCount').val() || 1; // По умолчанию 1 колесо
                
                console.log('Расчет стоимости:', { serviceCode: serviceCode, wheelCount: wheelCount });
                
                if (serviceCode) {
                    $.get('@Url.Action("GetServiceCost", "CompletedWorks")', { serviceCode: serviceCode })
                        .done(function(data) {
                            console.log('Ответ сервера:', data);
                            if (data.success) {
                                var total = data.cost * wheelCount;
                                $('#WorkTotal').val(total.toFixed(2));
                                console.log('Установлена стоимость:', total.toFixed(2));
                            } else {
                                console.error('Ошибка получения стоимости услуги:', data.message);
                            }
                        })
                        .fail(function(xhr, status, error) {
                            console.error('Ошибка при запросе стоимости услуги:', error);
                            console.error('Статус:', status);
                            console.error('Ответ:', xhr.responseText);
                        });
                } else {
                    $('#WorkTotal').val('');
                    console.log('Очищено поле стоимости');
                }
            }
            
            // Обработчики событий для автоматического расчета
            $('#ServiceCode').on('change', function() {
                console.log('Изменена услуга:', $(this).val());
                // Если количество колес не указано
                if (!$('#WheelCount').val()) {
                    $('#WheelCount').val(1);
                }
                calculateTotal();
            });
            
            $('#WheelCount').on('input change', function() {
                console.log('Изменено количество колес:', $(this).val());
                // Пересчитываем только если услуга уже выбрана
                if ($('#ServiceCode').val()) {
                    calculateTotal();
                }
            });
            
            console.log('ServiceCode элемент найден:', $('#ServiceCode').length > 0);
            console.log('WheelCount элемент найден:', $('#WheelCount').length > 0);
            console.log('WorkTotal элемент найден:', $('#WorkTotal').length > 0);
        });
    </script>
}