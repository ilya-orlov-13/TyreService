@model IEnumerable<TyreServiceApp.Models.CompletedWork>

@{
    ViewData["Title"] = "Выполненные работы";
}

<partial name="_CardGridStyles" />
<style>
    .work-card {
        gap: 12px;
        width: 100%;
        height: 100%;
        box-sizing: border-box;
    }
    .work-card-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
    }
    .work-card-header .work-order {
        font-weight: 700;
        font-size: 1rem;
        color: #000;
    }
    .work-card-header .work-service {
        font-size: 0.8rem;
    }
    .work-card-body {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        font-size: 0.85rem;
        color: #555;
    }
    .work-card-body .detail-item {
        display: flex;
        align-items: center;
        gap: 4px;
    }
    .work-card-body .badge {
        font-size: 0.75rem;
        padding: 3px 10px;
        border-radius: 20px;
    }
    .work-card-body .total-amount {
        font-weight: 700;
        color: #000;
        font-size: 1.05rem;
    }
    .work-card-footer {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 6px;
        padding-top: 8px;
        border-top: 1px solid #f0f0f0;
    }
    .work-card-footer a {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        transition: background 0.2s;
    }
    .work-card-footer a:hover {
        background: #f0f0f0;
    }
</style>

<div class="container-fluid pt-2 pb-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold m-0">
            <i class="bi bi-check-circle-fill me-2"></i> Выполненные работы
        </h3>
        <a asp-action="Create" class="btn btn-dark">
            <i class="bi bi-plus-circle me-1"></i> Добавить работу
        </a>
    </div>

    @if (Model.Any())
    {
        <div class="works-grid">
            @foreach (var item in Model)
            {
                <div class="work-card">
                    <div class="work-card-header">
                        <span class="work-order">Заказ #@Html.DisplayFor(modelItem => item.OrderNumber)</span>
                        <span class="work-service badge bg-info">@Html.DisplayFor(modelItem => item.ServiceCode)</span>
                    </div>
                    <div class="work-card-body">
                        <span class="detail-item">
                            <i class="bi bi-person-badge text-secondary"></i> Мастер #@Html.DisplayFor(modelItem => item.MasterId)
                        </span>
                        <span class="detail-item">
                            <i class="bi bi-circle text-warning"></i> @Html.DisplayFor(modelItem => item.WheelCount) колес
                        </span>
                        <span class="detail-item">
                            <i class="bi bi-clock text-info"></i> @Html.DisplayFor(modelItem => item.CompletionTimeMin) мин
                        </span>
                        <span class="total-amount">@Html.DisplayFor(modelItem => item.WorkTotal) ₽</span>
                    </div>
                    <div class="work-card-footer">
                        <a asp-action="Details" asp-route-id="@item.WorkId" class="btn btn-outline-info btn-sm" title="Подробнее">
                            <i class="bi bi-eye"></i>
                        </a>
                        <a asp-action="Edit" asp-route-id="@item.WorkId" class="btn btn-outline-primary btn-sm" title="Редактировать">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <a asp-action="Delete" asp-route-id="@item.WorkId" class="btn btn-outline-danger btn-sm" title="Удалить">
                            <i class="bi bi-trash"></i>
                        </a>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5 border rounded bg-light">
            <i class="bi bi-check-circle text-muted" style="font-size: 3rem;"></i>
            <h4 class="mt-3">Выполненные работы не найдены</h4>
            <p class="text-muted">Добавьте первую выполненную работу, чтобы начать учет.</p>
        </div>
    }
</div>
