<style>
    .view-toggle-bar {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 16px;
    }

    .view-toggle-btn {
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 6px 14px;
        border: 1.5px solid #ccc;
        border-radius: 10px;
        background: #fff;
        color: #666;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .view-toggle-btn:hover {
        border-color: #000;
        color: #000;
    }

    .view-toggle-btn.active {
        background: #000;
        border-color: #000;
        color: #fff;
    }

    .view-toggle-btn svg {
        width: 16px;
        height: 16px;
    }

    /* Table view styles */
    .view-table {
        display: none;
    }

    body.table-mode .view-cards {
        display: none;
    }

    body.table-mode .view-table {
        display: block;
        max-width: 1200px;
        margin: 0 auto;
    }

    .data-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
        background: #fff;
        border-radius: 14px;
        overflow: hidden;
        box-shadow: 0 2px 12px rgba(0,0,0,0.07);
    }

    .data-table thead th {
        background: #1a1a1a;
        color: #fff;
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.8px;
        padding: 14px 18px;
        text-align: left;
        white-space: nowrap;
        border-bottom: 2px solid #000;
    }

    .data-table tbody td {
        padding: 12px 18px;
        font-size: 13px;
        color: #333;
        border-bottom: 1px solid #eee;
        vertical-align: middle;
        transition: background 0.15s;
    }

    .data-table tbody tr:hover td {
        background: #f7f7f8;
    }

    .data-table tbody tr:last-child td {
        border-bottom: none;
    }

    .data-table .table-actions {
        display: flex;
        gap: 6px;
        align-items: center;
    }

    .data-table .table-actions {
        display: flex;
        gap: 4px;
        align-items: center;
        justify-content: flex-end;
    }

    .data-table .table-actions a,
    .data-table .table-actions button {
        width: 30px;
        height: 30px;
        border-radius: 8px;
        border: 1px solid #e0e0e0;
        display: flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        color: #999;
        background: #fff;
        cursor: pointer;
        transition: all 0.15s ease;
        padding: 0;
    }

    .data-table .table-actions a:hover,
    .data-table .table-actions button:hover {
        border-color: #000;
        color: #000;
        box-shadow: 0 1px 4px rgba(0,0,0,0.08);
    }

    .data-table .table-actions .danger:hover {
        border-color: #dc2626;
        background: #fef2f2;
        color: #dc2626;
        box-shadow: 0 1px 4px rgba(220,38,38,0.12);
    }

    .data-table .table-actions svg {
        width: 14px;
        height: 14px;
    }

    /* Inline editing */
    .inline-edit {
        cursor: pointer;
        border-bottom: 1px dashed #ccc;
        transition: border-color 0.15s;
    }

    .inline-edit:hover {
        border-bottom-color: #000;
    }

    .inline-edit-input {
        width: 100%;
        border: 1px solid #000;
        border-radius: 6px;
        padding: 4px 8px;
        font-size: 13px;
        font-family: inherit;
        box-sizing: border-box;
        background: #fff;
    }

    @@media (max-width: 768px) {
        body.table-mode .view-table {
            display: block;
        }
        .data-table thead {
            display: none;
        }
        .data-table tbody td {
            display: flex;
            padding: 8px 12px;
            border-bottom: 1px solid #f0f0f0;
        }
        .data-table tbody td::before {
            content: attr(data-label);
            font-weight: 700;
            width: 100px;
            flex-shrink: 0;
            color: #888;
            font-size: 11px;
            text-transform: uppercase;
        }
        .data-table tbody tr {
            display: block;
            padding: 8px 0;
            border-bottom: 2px solid #e0e0e0;
        }
        .data-table tbody tr:last-child {
            border-bottom: none;
        }
    }
</style>

<div class="view-toggle-bar">
    <button type="button" class="view-toggle-btn active" data-mode="cards" onclick="toggleView('cards')">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>
        Карточки
    </button>
    <button type="button" class="view-toggle-btn" data-mode="table" onclick="toggleView('table')">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="3" y1="9" x2="21" y2="9"></line><line x1="9" y1="3" x2="9" y2="21"></line></svg>
        Таблица
    </button>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        var savedMode = localStorage.getItem('viewMode') || 'cards';
        if (savedMode === 'table') {
            document.body.classList.add('table-mode');
            var btn = document.querySelector('.view-toggle-btn[data-mode="table"]');
            if (btn) btn.classList.add('active');
            var cardBtn = document.querySelector('.view-toggle-btn[data-mode="cards"]');
            if (cardBtn) cardBtn.classList.remove('active');
        }
    });

    function toggleView(mode) {
        document.body.classList.remove('table-mode');
        document.querySelectorAll('.view-toggle-btn').forEach(function (b) {
            b.classList.remove('active');
        });
        if (mode === 'table') {
            document.body.classList.add('table-mode');
            document.querySelector('.view-toggle-btn[data-mode="table"]').classList.add('active');
        } else {
            document.querySelector('.view-toggle-btn[data-mode="cards"]').classList.add('active');
        }
        localStorage.setItem('viewMode', mode);
    }
</script>
