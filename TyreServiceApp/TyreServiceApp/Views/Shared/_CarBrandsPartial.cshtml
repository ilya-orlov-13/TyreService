<div class="form-group">
    <label asp-for="Brand" class="form-label fw-semibold">
        <i class="bi bi-tag text-dark"></i> Марка
    </label>
    <select asp-for="Brand" class="form-control" id="BrandSelect">
        <option value="">— Выберите марку —</option>
        @foreach (var brand in brandModels.Keys)
        {
            <option value="@brand">@brand</option>
        }
    </select>
    <span asp-validation-for="Brand" class="text-danger"></span>
</div>

<div class="form-group">
    <label asp-for="Model" class="form-label fw-semibold">
        <i class="bi bi-tag text-dark"></i> Модель
    </label>
    <select asp-for="Model" class="form-control" id="ModelSelect">
        <option value="">— Выберите модель —</option>
        @foreach (var kvp in brandModels)
        {
            foreach (var model in kvp.Value)
            {
                <option value="@(model)" data-brand="@kvp.Key">@(model)</option>
            }
        }
    </select>
    <span asp-validation-for="Model" class="text-danger"></span>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        var brandSelect = document.getElementById('BrandSelect');
        var modelSelect = document.getElementById('ModelSelect');
        if (!brandSelect || !modelSelect) return;
        var options = Array.from(modelSelect.querySelectorAll('option[data-brand]'));
        function filter(brand) {
            options.forEach(function (o) {
                o.style.display = (o.getAttribute('data-brand') === brand) ? '' : 'none';
            });
            if (brand) {
                var cur = modelSelect.value;
                var valid = cur && options.some(function (o) { return o.value === cur && o.getAttribute('data-brand') === brand; });
                if (!valid) modelSelect.value = '';
            }
        }
        brandSelect.addEventListener('change', function () { filter(this.value); });
        filter(brandSelect.value);
    });
</script>
