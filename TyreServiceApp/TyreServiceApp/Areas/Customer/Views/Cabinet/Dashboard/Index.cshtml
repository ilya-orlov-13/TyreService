@using TyreServiceApp.Models
@{
    var client = ViewBag.Client as Client;
    var orders = ViewBag.Orders as List<Order> ?? new();
    ViewData["Title"] = "Личный кабинет";
}

<div class="main-content">
    <h4 class="fw-bold mb-4">
        Здравствуйте, @client?.FullName
    </h4>

    <div class="row g-4">
        <div class="col-lg-6">
            <div class="animated-card card-recent h-100">
                <div class="animated-card-inner">
                    <div class="card-title-row">
                        <h5 class="card-title mb-0">
                            <i class="bi bi-car-front me-2"></i>Мои автомобили
                        </h5>
                        <a asp-action="AddCar" class="btn-add-car" title="Добавить автомобиль">
                            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                <line x1="12" y1="5" x2="12" y2="19"></line>
                                <line x1="5" y1="12" x2="19" y2="12"></line>
                            </svg>
                        </a>
                    </div>

                    @await Html.PartialAsync("Cars/_CarsList", client?.Cars)
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="animated-card card-recent h-100">
                <div class="animated-card-inner">
                    <h5 class="card-title mb-3">
                        <i class="bi bi-clock-history me-2"></i>Последние заказы
                    </h5>

                    @if (orders.Any())
                    {
                        <div class="orders-mini-grid">
                            @foreach (var order in orders)
                            {
                                <div class="order-mini-card">
                                    <div class="order-mini-top">
                                        <span class="order-mini-number">#@order.OrderNumber</span>
                                        <span class="order-mini-status @(order.IsCompleted() ? "paid" : "unpaid")">
                                            @(order.IsCompleted() ? "Оплачено" : "В работе")
                                        </span>
                                    </div>
                                    <div class="order-mini-date">
                                        <i class="bi bi-calendar me-1"></i>@(order.ScheduledAt?.ToString("dd.MM.yyyy") ?? order.OrderDate.ToString("dd.MM.yyyy")) <span class="time-slot-badge @(order.ScheduledAt.HasValue ? "" : "fallback")">@(order.ScheduledAt?.ToString("HH:mm") ?? order.OrderDate.ToString("HH:mm"))</span>
                                    </div>
                                    @if (order.Car != null)
                                    {
                                        <div class="order-mini-car">
                                            <i class="bi bi-car-front me-1"></i>@order.Car.FullInfo
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-center text-muted py-5">
                            <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                            У вас пока нет заказов
                        </div>
                    }

                    <div class="text-center mt-3">
                        <a asp-action="Orders" class="btn btn-outline-dark btn-sm">
                            <i class="bi bi-list-ul me-1"></i> Все заказы
                        </a>
                        @if (orders.Any())
                        {
                            <a asp-action="Book" class="btn btn-outline-dark btn-sm ms-2">
                                <i class="bi bi-plus-circle me-1"></i> Добавить заказ
                            </a>
                        }
                        else
                        {
                            <a asp-action="Book" class="btn btn-outline-dark btn-sm ms-2">
                                <i class="bi bi-calendar-plus me-1"></i> Записаться
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Photo Viewer Lightbox (вне animated-card-inner, чтобы position:fixed работал) -->
<div id="pvOverlay" class="photo-viewer" style="display:none;" onclick="closePv(event)">
    <div class="photo-viewer-content" onclick="event.stopPropagation()">
        <img id="pvImage" src="" alt="Фото автомобиля">
        <div class="pv-counter" id="pvCounter"></div>
        <div class="pv-nav-dots">
            <button class="pv-dot" id="pvPrev" onclick="pvChange(-1)">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
            </button>
            <button class="pv-dot" id="pvNext" onclick="pvChange(1)">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
            </button>
        </div>
    </div>
</div>

<style>
    .orders-mini-grid {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .order-mini-card {
        background: #ffffff;
        border: 1.5px solid #c0c0c5;
        border-radius: 12px;
        padding: 10px 14px;
        display: flex;
        flex-direction: column;
        gap: 4px;
        transition: border-color 0.2s ease;
    }

    .order-mini-card:hover {
        border-color: #000000;
    }

    .order-mini-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 8px;
    }

    .order-mini-number {
        font-weight: 700;
        font-size: 14px;
        color: #212529;
    }

    .order-mini-date {
        font-size: 11px;
        color: #6c757d;
    }

    .order-mini-status {
        font-size: 10px;
        font-weight: 700;
        padding: 2px 10px;
        border-radius: 20px;
        white-space: nowrap;
        flex-shrink: 0;
    }

    .order-mini-status.paid {
        background: #d1e7dd;
        color: #0f5132;
    }

    .order-mini-status.unpaid {
        background: #fff3cd;
        color: #856404;
    }

    .order-mini-car {
        font-size: 12px;
        color: #495057;
    }

    .photo-viewer {
        position: fixed; top: 0; left: 0; right: 0; bottom: 0;
        background: rgba(0, 0, 0, 0.9);
        z-index: 99999;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .photo-viewer-content {
        position: relative;
        display: flex;
        flex-direction: column;
        align-items: center;
        max-width: 90vw;
        max-height: 90vh;
    }
    .photo-viewer-content img {
        max-width: 90vw;
        max-height: 80vh;
        object-fit: contain;
        border-radius: 8px;
    }
    .pv-counter {
        color: #aaa;
        font-size: 13px;
        margin-top: 10px;
        font-weight: 500;
    }
    .pv-nav-dots {
        display: flex;
        gap: 20px;
        margin-top: 12px;
    }
    .pv-dot {
        width: 44px; height: 44px; border-radius: 50%;
        background: none;
        border: 1.5px solid rgba(255,255,255,0.4);
        color: rgba(255,255,255,0.7);
        font-size: 22px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background 0.2s, border-color 0.2s, color 0.2s;
    }
    .pv-dot:hover { background: rgba(255,255,255,0.1); border-color: #fff; color: #fff; }
    .time-slot-badge {
        background: #000;
        color: #fff;
        font-size: 10px;
        font-weight: 700;
        padding: 2px 8px;
        border-radius: 6px;
        margin-left: 6px;
        letter-spacing: 0.5px;
    }
    .time-slot-badge.fallback {
        background: #e2e8f0;
        color: #64748b;
    }
</style>

<script>
    var pvPhotos = [];
    var pvIndex = 0;

    function openPv(el) {
        var photosStr = el.getAttribute('data-photos');
        if (!photosStr) return;
        try { pvPhotos = JSON.parse(photosStr); } catch(e) { return; }
        if (!pvPhotos.length) return;
        pvIndex = 0;
        showPvPhoto();
        document.getElementById('pvOverlay').style.display = 'flex';
        document.body.style.overflow = 'hidden';
    }

    function closePv() {
        document.getElementById('pvOverlay').style.display = 'none';
        document.body.style.overflow = '';
    }

    function showPvPhoto() {
        document.getElementById('pvImage').src = pvPhotos[pvIndex];
        var counter = document.getElementById('pvCounter');
        counter.textContent = (pvIndex + 1) + ' из ' + pvPhotos.length;
        var hasNav = pvPhotos.length > 1;
        document.getElementById('pvPrev').style.display = hasNav ? '' : 'none';
        document.getElementById('pvNext').style.display = hasNav ? '' : 'none';
    }

    function pvChange(delta) {
        if (!pvPhotos.length) return;
        pvIndex = (pvIndex + delta + pvPhotos.length) % pvPhotos.length;
        showPvPhoto();
    }

    document.addEventListener('keydown', function(e) {
        if (document.getElementById('pvOverlay').style.display !== 'flex') return;
        if (e.key === 'Escape') closePv();
        if (e.key === 'ArrowLeft') pvChange(-1);
        if (e.key === 'ArrowRight') pvChange(1);
    });
</script>
