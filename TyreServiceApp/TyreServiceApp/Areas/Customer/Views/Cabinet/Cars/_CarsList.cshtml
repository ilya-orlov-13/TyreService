@model IEnumerable<Car>
@using System.Text.Json

@functions {
    List<string> GetAllPhotos(Car car)
    {
        var photos = new List<string>();
        if (!string.IsNullOrEmpty(car.PhotoPath))
            photos.Add(car.PhotoPath);
        if (!string.IsNullOrEmpty(car.AdditionalPhotos))
        {
            try
            {
                var additional = JsonSerializer.Deserialize<List<string>>(car.AdditionalPhotos);
                if (additional != null)
                    photos.AddRange(additional);
            }
            catch { }
        }
        return photos;
    }

    string[] ParsePlate(string plate)
    {
        if (string.IsNullOrEmpty(plate) || plate.Length < 6)
            return new[] { plate ?? "", "", "", "" };
        var p = plate.Trim().ToUpperInvariant();
        return new[]
        {
            p.Length > 0 ? p[0].ToString() : "",
            p.Length > 3 ? p[1..4] : "",
            p.Length > 5 ? p[4..Math.Min(6, p.Length)] : "",
            p.Length > 6 ? p[6..] : ""
        };
    }
}

@if (Model.Any())
{
    <div class="cars-grid">
        @foreach (var car in Model)
        {
            var allPhotos = GetAllPhotos(car);
            var photosJson = JsonSerializer.Serialize(allPhotos);
            var photoAttr = photosJson.Replace("\"", "&quot;");
            var parts = ParsePlate(car.LicensePlate);
            <div class="car-card-wrapper" onclick="viewCar(@car.CarId)">
                <div class="car-card">
                    <div class="card-top-row">
                        <div class="car-image-wrapper" onclick="event.stopPropagation();">
                            @if (allPhotos.Count > 0)
                            {
                                <div class="car-thumb-wrap">
                                    <img src="@allPhotos[0]" alt="@car.Brand @car.Model"
                                         class="car-image" style="cursor:pointer"
                                         data-photos='@Html.Raw(photoAttr)'
                                         onclick="openPv(this)">
                                    @if (allPhotos.Count > 1)
                                    {
                                        <span class="photo-count-badge">+@(allPhotos.Count - 1)</span>
                                    }
                                </div>
                            }
                            else
                            {
                                <img src="~/images/default-car.png" alt="@car.Brand @car.Model" class="car-image">
                            }
                        </div>
                        <div class="brand-title">@car.Brand<br>@car.Model</div>
                        <div class="plate-mobile-wrap">
                            <div class="license-plate">
                                <div class="inner-frame">
                                    <div class="left-section">
                                        <span class="letter">@parts[0]</span>
                                        <span class="digits">@parts[1]</span>
                                        <span class="letter">@parts[2]</span>
                                    </div>
                                    @if (!string.IsNullOrEmpty(parts[3]))
                                    {
                                        <div class="divider"></div>
                                        <div class="right-section">
                                            <div class="region-code">@parts[3]</div>
                                            <div class="country-block">
                                                <span class="rus-text">RUS</span>
                                                <div class="flag">
                                                    <div class="stripe white"></div>
                                                    <div class="stripe blue"></div>
                                                    <div class="stripe red"></div>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="card-bottom-row">
                        <div class="plate-desktop">
                            <div class="plate-wrapper">
                            <div class="license-plate">
                                <div class="inner-frame">
                                    <div class="left-section">
                                        <span class="letter">@parts[0]</span>
                                        <span class="digits">@parts[1]</span>
                                        <span class="letter">@parts[2]</span>
                                    </div>
                                    @if (!string.IsNullOrEmpty(parts[3]))
                                    {
                                        <div class="divider"></div>
                                        <div class="right-section">
                                            <div class="region-code">@parts[3]</div>
                                            <div class="country-block">
                                                <span class="rus-text">RUS</span>
                                                <div class="flag">
                                                    <div class="stripe white"></div>
                                                    <div class="stripe blue"></div>
                                                    <div class="stripe red"></div>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                            </div>
                        </div>
                        <div style="display:flex;gap:6px;align-items:center;margin-left:auto" onclick="event.stopPropagation()">
                            <a asp-action="EditCar" asp-route-id="@car.CarId"
                               class="delete-btn" aria-label="Редактировать"
                               style="background:#555;text-decoration:none;display:flex;align-items:center;justify-content:center">
                                <svg class="trash-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M17 3a2.828 2.828 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5L17 3z"></path>
                                </svg>
                            </a>
                            <button type="button" class="delete-btn" aria-label="Удалить"
                                    onclick="event.stopPropagation(); showDeleteModal(@car.CarId, '@car.Brand @car.Model', '@car.LicensePlate')">
                                <svg class="trash-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <polyline points="3 6 5 6 21 6"></polyline>
                                    <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                                    <line x1="10" y1="11" x2="10" y2="17"></line>
                                    <line x1="14" y1="11" x2="14" y2="17"></line>
                                </svg>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>



    <!-- Delete Modal -->
    <div id="deleteModal" class="modal-overlay" style="display:none;" onclick="closeDeleteModal(event)">
        <div class="modal-content" onclick="event.stopPropagation()">
            <div class="modal-header">
                <h3 class="modal-title">Удалить автомобиль?</h3>
            </div>
            <div class="modal-body">
                <p class="modal-text">Вы уверены, что хотите удалить</p>
                <p id="deleteCarInfo" class="modal-car-info"></p>
                <p class="modal-hint">Это действие нельзя отменить.</p>
            </div>
            <form id="deleteForm" method="post" asp-action="DeleteCar" asp-controller="Cabinet">
                @Html.AntiForgeryToken()
                <input type="hidden" id="deleteCarId" name="id" value="" />
                <div class="modal-actions">
                    <button type="button" class="modal-btn modal-btn-cancel" onclick="closeDeleteModal()">Отмена</button>
                    <button type="submit" class="modal-btn modal-btn-delete">
                        <svg class="trash-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:16px;height:16px;">
                            <polyline points="3 6 5 6 21 6"></polyline>
                            <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                            <line x1="10" y1="11" x2="10" y2="17"></line>
                            <line x1="14" y1="11" x2="14" y2="17"></line>
                        </svg>
                        Удалить
                    </button>
                </div>
            </form>
        </div>
    </div>

    <style>
        .car-thumb-wrap {
            position: relative;
            width: 100%;
            height: 100%;
        }
        .car-thumb-wrap .car-image {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }
        .photo-count-badge {
            position: absolute;
            bottom: 6px;
            right: 6px;
            background: rgba(0,0,0,0.7);
            color: #fff;
            font-size: 11px;
            font-weight: 600;
            padding: 2px 8px;
            border-radius: 10px;
            pointer-events: none;
        }

        @@font-face {
            font-family: 'RoadNumbersCyr';
            src: url('/fonts/roadnumberscyr_regular.otf') format('opentype');
            font-weight: normal;
            font-style: normal;
        }

        .plate-desktop {
            display: inline-block;
        }
        .plate-wrapper {
            transform-origin: left center;
        }
        .license-plate {
            display: inline-flex;
            box-sizing: border-box;
            font-family: "RoadNumbersCyr", "Arial", sans-serif;
            user-select: none;
            max-width: 100%;
            position: relative;
            transform-style: preserve-3d;
            overflow: hidden;
        }
        .license-plate .inner-frame {
            display: flex;
            border: 3px solid #111111;
            border-radius: 6px;
            box-sizing: border-box;
            overflow: hidden;
            background: linear-gradient(135deg, #fcfcfc 0%, #f5f5f5 40%, #efefef 100%);
            box-shadow:
                inset 0 1px 0 rgba(255,255,255,0.9),
                inset 0 -1px 0 rgba(0,0,0,0.04),
                0 2px 4px rgba(0,0,0,0.12),
                0 1px 2px rgba(0,0,0,0.08);
            position: relative;
        }
        .license-plate .inner-frame::after {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            background: repeating-linear-gradient(
                90deg,
                transparent,
                transparent 2px,
                rgba(255,255,255,0.15) 2px,
                rgba(255,255,255,0.15) 3px
            );
            pointer-events: none;
            z-index: 1;
        }
        .license-plate .left-section {
            flex: 1;
            display: flex;
            align-items: flex-end;
            justify-content: space-between;
            padding: 0 10px 10px 10px;
            box-sizing: border-box;
            position: relative;
            z-index: 2;
        }
        .license-plate .letter {
            font-family: "RoadNumbersCyr", "Arial", sans-serif;
            font-size: 42px;
            line-height: 1;
            letter-spacing: 0.1em;
            color: #000000;
        }
        .license-plate .digits {
            font-family: "RoadNumbersCyr", "Arial", sans-serif;
            font-size: 50px;
            line-height: 1;
            letter-spacing: 0.1em;
            color: #000000;
        }
        .license-plate .divider {
            width: 3px;
            flex-shrink: 0;
            background: #111111;
            position: relative;
            z-index: 2;
        }
        .license-plate .right-section {
            width: 60px;
            flex-shrink: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: space-between;
            padding: 6px 6px 6px 6px;
            box-sizing: border-box;
            position: relative;
            z-index: 2;
        }
        .license-plate .region-code {
            font-family: "RoadNumbersCyr", "Arial", sans-serif;
            font-size: 30px;
            font-weight: 400;
            line-height: 1;
            color: #000000;
            margin-top: 2px;
        }
        .license-plate .country-block {
            display: flex;
            align-items: center;
            gap: 3px;
            box-sizing: border-box;
        }
        .license-plate .rus-text {
            font-family: "Arial", sans-serif;
            font-size: 10px;
            font-weight: 700;
            line-height: 1;
            color: #000000;
        }
        .license-plate .flag {
            width: 12px;
            height: 7px;
            border: 1px solid #000000;
            display: flex;
            flex-direction: column;
            box-sizing: border-box;
            border-radius: 1px;
        }
        .license-plate .stripe { flex: 1; }
        .license-plate .stripe.white { background: #ffffff; }
        .license-plate .stripe.blue { background: #0039a6; }
        .license-plate .stripe.red { background: #d52b1e; }

        .plate-mobile-wrap {
            display: none;
        }

        .plate-desktop .license-plate .letter {
            font-size: 32px;
        }
        .plate-desktop .license-plate .digits {
            font-size: 38px;
        }
        .plate-desktop .license-plate .left-section {
            padding: 0 8px 8px 8px;
        }
        .plate-desktop .license-plate .right-section {
            width: 54px;
            padding: 6px 5px;
        }
        .plate-desktop .license-plate .region-code {
            font-size: 22px;
            margin-top: 0;
        }
        .plate-desktop .license-plate .rus-text {
            font-size: 9px;
        }
        .plate-desktop .license-plate .flag {
            width: 10px;
            height: 6px;
        }

        @@media (max-width: 576px) {
            .plate-mobile-wrap {
                display: flex;
                align-items: center;
                flex-shrink: 1;
                min-width: 0;
            }
            .plate-mobile-wrap .license-plate {
                transform: none;
            }
            .plate-mobile-wrap .license-plate .inner-frame {
                border-width: 2px;
            }
            .plate-mobile-wrap .license-plate .letter {
                font-size: 26px;
            }
            .plate-mobile-wrap .license-plate .digits {
                font-size: 32px;
            }
            .plate-mobile-wrap .license-plate .left-section {
                padding: 5px 5px 2px 5px;
                align-items: flex-end;
            }
            .plate-mobile-wrap .license-plate .right-section {
                width: 36px;
                padding: 2px 3px;
                justify-content: center;
                gap: 2px;
            }
            .plate-mobile-wrap .license-plate .region-code {
                font-size: 14px;
                margin-top: 0;
                line-height: 1;
            }
            .plate-mobile-wrap .license-plate .rus-text {
                font-size: 6px;
            }
            .plate-mobile-wrap .license-plate .flag {
                width: 8px;
                height: 4px;
            }
            .plate-mobile-wrap .license-plate .country-block {
                gap: 1px;
            }
            .plate-mobile-wrap .license-plate .divider {
                width: 2px;
            }
            .plate-desktop {
                display: none !important;
            }
        }
    </style>

    <script>
        function viewCar(carId) {
            window.location.href = '/Customer/Cabinet/Details/' + carId;
        }

        function showDeleteModal(carId, carName, plate) {
            document.getElementById('deleteCarId').value = carId;
            document.getElementById('deleteCarInfo').textContent = carName + ' (' + plate + ')';
            var modal = document.getElementById('deleteModal');
            modal.style.display = 'flex';
            setTimeout(function() { modal.classList.add('modal-show'); }, 10);
        }

        function closeDeleteModal(e) {
            if (e && e.target !== e.currentTarget) return;
            var modal = document.getElementById('deleteModal');
            modal.classList.remove('modal-show');
            setTimeout(function() { modal.style.display = 'none'; }, 300);
        }
    </script>
}
else
{
    <div class="text-center text-muted py-4">
        <i class="bi bi-car-front fs-1 d-block mb-2"></i>
        У вас пока нет добавленных автомобилей
    </div>
}
