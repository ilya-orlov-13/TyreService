<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Рабочее место</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&family=Montserrat:wght@900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
    <style>
        .dock-outer {
            display: flex;
            justify-content: flex-end; 
            width: 100%;
        }

        .nav-container {
            position: relative;
            display: flex;
            align-items: flex-start; 
            width: fit-content;
            background-color: transparent !important;
            border: none !important;
            border-radius: 1rem;
            padding: 10px;
            height: 70px;
            overflow: visible;
            gap: 0; 
        }

        .nav-button {
            position: relative;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 12px;
            background-color: #060010;
            border: 1px solid #222;
            cursor: pointer;
            outline: none;
            width: 50px;
            height: 50px;
            margin: 0 10px;
            transition: all 0.3s ease;
            text-decoration: none !important;
            color: #fff !important;
            z-index: 1;
        }

        .nav-button:hover, 
        .nav-item.active .nav-button {
            background-color: #ffffff !important;
            border-color: #ffffff !important;
            color: #000000 !important;
        }

        .nav-button:hover i,
        .nav-item.active .nav-button i {
            color: #000000 !important;
        }

        .nav-button i {
            font-size: 20px;
            transition: color 0.3s ease;
        }

        .dock-label {
            position: absolute;
            top: 100%; 
            left: 50%;
            margin-top: 15px;
            width: fit-content;
            white-space: nowrap;
            border-radius: 0.375rem;
            border: 1px solid #222;
            background-color: #060010;
            padding: 0.25rem 0.5rem;
            font-size: 0.75rem;
            color: #fff;
            transform: translateX(-50%);
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.2s ease;
            z-index: 1000;
        }

        .nav-button:hover .dock-label {
            opacity: 1;
        }

        .navbar-dark.bg-dark {
            background-color: #111111 !important;
            border-bottom: 1px solid #333;
            min-height: 90px;
        }

        .full-nav-container {
            display: flex;
            flex-grow: 1;
            justify-content: flex-end; 
            align-items: center;
        }

        .brand-text {
            color: white !important;
            font-size: 1.5rem;
            font-weight: 600;
            margin-left: 8px;
            letter-spacing: 0.5px;
        }

        .worker-desktop-info {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        /* Mobile account button */
        .mobile-account-btn {
            display: none;
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: #111;
            border: 1px solid #333;
            color: #fff;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            font-size: 18px;
            transition: background 0.2s;
        }
        .mobile-account-btn:active { background: #333; }

        /* Full-screen mobile overlay */
        .mobile-overlay {
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.5);
            backdrop-filter: blur(4px);
            z-index: 99999;
            display: none;
            opacity: 0;
            transition: opacity 0.25s ease;
        }
        .mobile-overlay.show { opacity: 1; }
        .mobile-overlay-panel {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            width: 100%;
            background: #111;
            display: flex;
            flex-direction: column;
            transform: translateY(-100%);
            transition: transform 0.35s ease;
        }
        .mobile-overlay.show .mobile-overlay-panel { transform: translateY(0); }
        .mobile-overlay-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 20px 20px 12px;
            border-bottom: 1px solid #222;
        }
        .mobile-overlay-header span { color: #fff; font-weight: 600; font-size: 16px; }
        .mobile-overlay-close {
            width: 36px; height: 36px; border-radius: 50%;
            background: none; border: 1px solid #333;
            color: #888; display: flex; align-items: center; justify-content: center;
            cursor: pointer; font-size: 18px;
            transition: background 0.2s, color 0.2s;
        }
        .mobile-overlay-close:hover { background: #111; color: #fff; }
        .mobile-overlay-body { flex: 1; overflow-y: auto; padding: 8px 0; }
        .mobile-overlay-link {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 14px 20px;
            color: #ccc;
            text-decoration: none;
            font-size: 15px;
            border: none;
            background: none;
            width: 100%;
            text-align: left;
            cursor: pointer;
            transition: background 0.15s, color 0.15s;
        }
        .mobile-overlay-link i { width: 22px; font-size: 18px; color: #666; flex-shrink: 0; }
        .mobile-overlay-link:active, .mobile-overlay-link:hover { background: #111; color: #fff; }
        .mobile-overlay-link:active i, .mobile-overlay-link:hover i { color: #fff; }
        .mobile-overlay-link.active-link { color: #fff; background: #111; }
        .mobile-overlay-link.active-link i { color: #fff; }
        .mobile-overlay-footer { padding: 12px 0; border-top: 1px solid #222; }
        .mobile-overlay-link.logout-link { color: #f87171; }
        .mobile-overlay-link.logout-link i { color: #f87171; }

        @@media (max-width: 991px) {
            .worker-desktop-info { display: none !important; }
            .mobile-account-btn { display: flex; }
            .navbar-dark.bg-dark { min-height: 60px; }
            .brand-text { font-size: 1.1rem; }
        }
    </style>
</head>
<body class="d-flex flex-column min-vh-100" style="background:#f1f5f9;font-family:'Inter',sans-serif;">
    <header>
        <nav class="navbar navbar-dark bg-dark shadow-sm">
            <div class="container-fluid">
                <div class="brand-container d-flex align-items-center" style="flex-grow:1;">
                    <a class="navbar-brand d-flex align-items-center" asp-area="Worker" asp-controller="Board" asp-action="Index">
                        <img src="~/images/logo.png" alt="Logo" style="height: 40px; width: auto;" />
                        <span class="brand-text fw-bold">Рабочее место</span>
                    </a>
                    <button class="mobile-account-btn ms-auto" type="button" onclick="toggleMobileMenu()" aria-label="Меню">
                        <i class="bi bi-person-circle"></i>
                    </button>
                </div>

                <div class="full-nav-container" style="flex-grow:0;">
                    <div class="dock-outer">
                        <div class="nav-container" id="navContainer">
                            @{
                                var currentController = ViewContext.RouteData.Values["Controller"]?.ToString();
                            }

                            <div class="nav-item @(currentController == "Board" ? "active" : "")">
                                <a asp-area="Worker" asp-controller="Board" asp-action="Index" class="nav-button">
                                    <i class="bi bi-kanban"></i>
                                    <div class="dock-label">Доска</div>
                                </a>
                            </div>

                            <div class="nav-item @(currentController == "Post" ? "active" : "")">
                                <a asp-area="Worker" asp-controller="Post" asp-action="Index" class="nav-button">
                                    <i class="bi bi-grid-3x3-gap"></i>
                                    <div class="dock-label">Посты</div>
                                </a>
                            </div>

                            <div class="nav-item">
                                <form asp-area="Worker" asp-controller="Auth" asp-action="Logout" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="nav-button">
                                        <i class="bi bi-box-arrow-right"></i>
                                        <div class="dock-label">Выйти</div>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                    <div class="worker-desktop-info ms-2">
                        <span class="text-light" style="font-size:13px;opacity:0.8;">
                            <i class="bi bi-person-badge me-1"></i>@User.Identity?.Name
                        </span>
                    </div>
                </div>
            </div>
        </nav>
        <!-- Mobile overlay -->
        <div class="mobile-overlay" id="mobileOverlay" onclick="if(event.target===this)closeMobileMenu()">
            <div class="mobile-overlay-panel">
                <div class="mobile-overlay-header">
                    <span>Рабочее место</span>
                    <button class="mobile-overlay-close" onclick="closeMobileMenu()"><i class="bi bi-x-lg"></i></button>
                </div>
                <div class="mobile-overlay-body">
                    <div style="padding:16px 20px;border-bottom:1px solid #222;margin-bottom:8px;">
                        <div style="color:#888;font-size:13px;">Вы вошли как</div>
                        <div style="color:#fff;font-weight:600;font-size:17px;margin-top:2px;">
                            <i class="bi bi-person-badge me-2"></i>@User.Identity?.Name
                        </div>
                    </div>
                    <a asp-area="Worker" asp-controller="Board" asp-action="Index" class="mobile-overlay-link @(currentController == "Board" ? "active-link" : "")" onclick="closeMobileMenu()">
                        <i class="bi bi-kanban"></i>Доска
                    </a>
                    <a asp-area="Worker" asp-controller="Post" asp-action="Index" class="mobile-overlay-link @(currentController == "Post" ? "active-link" : "")" onclick="closeMobileMenu()">
                        <i class="bi bi-grid-3x3-gap"></i>Посты
                    </a>
                </div>
                <div class="mobile-overlay-footer">
                    <form asp-area="Worker" asp-controller="Auth" asp-action="Logout" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="mobile-overlay-link logout-link">
                            <i class="bi bi-box-arrow-right"></i>Выйти
                        </button>
                    </form>
                </div>
            </div>
        </div>
        <script>
            function toggleMobileMenu() {
                var el = document.getElementById('mobileOverlay');
                el.style.display = 'block';
                requestAnimationFrame(function() { el.classList.add('show'); });
                document.body.style.overflow = 'hidden';
            }
            function closeMobileMenu() {
                var el = document.getElementById('mobileOverlay');
                el.classList.remove('show');
                setTimeout(function() { el.style.display = 'none'; document.body.style.overflow = ''; }, 300);
            }
        </script>
    </header>

    <main class="container-fluid py-3">
        @RenderBody()
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
