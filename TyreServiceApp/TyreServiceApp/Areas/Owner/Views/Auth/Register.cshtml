@{
    ViewData["Title"] = "Регистрация владельца";
    Layout = null;
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Шиномонтаж у Бориса</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <style>
        :root { --button_radius: 0.75em; --button_outline_color: #000000; --button_color: #e8e8e8; }
        body {
            background: #f8f9fa;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            padding: 20px;
        }
        .main-3d-wrapper {
            position: relative;
            background: var(--button_outline_color);
            border-radius: var(--button_radius);
            display: block;
            width: 100%;
            max-width: 450px;
        }
        .main-3d-inner {
            display: block;
            box-sizing: border-box;
            border: 2px solid var(--button_outline_color);
            border-radius: var(--button_radius);
            background: white;
            padding: 30px;
            transform: translateY(-0.15em);
        }
        .modern-btn {
            padding: 12px 24px;
            border: none;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            text-decoration: none;
            width: 100%;
            justify-content: center;
        }
        .modern-btn-primary { background-color: #000000; color: white; }
        .modern-btn-primary:hover { background-color: #333333; }
        .details-row {
            display: flex;
            flex-direction: column;
            padding: 12px 0;
            border-bottom: 1px solid #f1f5f9;
        }
        .details-row:last-child { border-bottom: none; }
        .details-label {
            font-weight: 600;
            color: #64748b;
            font-size: 14px;
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 8px;
        }
        .form-input {
            width: 100%;
            padding: 12px 16px;
            border: 2px solid #e5e7eb;
            border-radius: 8px;
            font-size: 14px;
            background: #ffffff;
            font-weight: 500;
            color: #1e293b;
        }
        .form-input:focus {
            outline: none;
            border-color: #000000;
            box-shadow: 0 0 0 3px rgba(0, 0, 0, 0.1);
        }
        .error-alert {
            background: #fef2f2;
            border: 1px solid #fecaca;
            color: #dc2626;
            padding: 12px 16px;
            border-radius: 8px;
            font-size: 14px;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .login-title {
            font-size: 1.5rem;
            font-weight: 700;
            color: #212529;
            margin: 0 0 8px 0;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .login-description { color: #64748b; font-size: 14px; margin-bottom: 24px; }
        .divider-text {
            display: flex;
            align-items: center;
            gap: 12px;
            color: #94a3b8;
            font-size: 13px;
            margin: 16px 0;
        }
        .divider-text::before,
        .divider-text::after {
            content: '';
            flex: 1;
            height: 1px;
            background: #e5e7eb;
        }
        .register-link {
            text-align: center;
            margin-top: 20px;
            padding-top: 16px;
            border-top: 1px solid #f1f5f9;
        }
        .register-link a { color: #000000; text-decoration: none; font-weight: 600; }
        .register-link a:hover { text-decoration: underline; }
        @@media (max-width: 576px) {
            .main-3d-inner { padding: 20px; }
            body { padding: 8px; }
            .form-input { font-size: 16px; padding: 14px 16px; }
            .modern-btn { padding: 14px 20px; font-size: 16px; }
        }
    </style>
</head>
<body>
    <div class="main-3d-wrapper">
        <div class="main-3d-inner">
            
            <a href="@Url.Action("Index", "Home", new { area = "" })" class="text-decoration-none text-muted" style="font-size:13px;display:inline-flex;align-items:center;gap:4px;margin-bottom:12px;">
                <i class="bi bi-arrow-left"></i> На главную
            </a>

            <div class="d-flex justify-content-center align-items-center mb-4">
                <h3 class="login-title">
                    <i class="bi bi-person-plus"></i> Регистрация владельца
                </h3>
            </div>
            
            <p class="login-description text-center">
                Создайте учётную запись владельца
            </p>

            <form method="post">
                @if (ViewBag.Error != null)
                {
                    <div class="error-alert">
                        <i class="bi bi-exclamation-triangle-fill"></i> @ViewBag.Error
                    </div>
                }

                <div class="mb-4">
                    <div class="details-row">
                        <div class="details-label"><i class="bi bi-person"></i> Логин:</div>
                        <input type="text" name="login" class="form-input" placeholder="Придумайте логин" required />
                    </div>
                    <div class="details-row">
                        <div class="details-label"><i class="bi bi-person-badge"></i> Имя (необязательно):</div>
                        <input type="text" name="fullName" class="form-input" placeholder="Иванов Иван" />
                    </div>
                    <div class="details-row">
                        <div class="details-label"><i class="bi bi-envelope"></i> Email (необязательно):</div>
                        <input type="email" name="email" class="form-input" placeholder="owner@example.com" />
                    </div>
                    <div class="details-row">
                        <div class="details-label"><i class="bi bi-lock"></i> Пароль:</div>
                        <input type="password" name="password" class="form-input" placeholder="Не менее 6 символов" required />
                    </div>
                    <div class="details-row">
                        <div class="details-label"><i class="bi bi-lock-fill"></i> Повторите пароль:</div>
                        <input type="password" name="confirmPassword" class="form-input" placeholder="Повторите пароль" required />
                    </div>
                </div>

                <button type="submit" class="modern-btn modern-btn-primary">
                    <i class="bi bi-check-lg"></i> Зарегистрироваться
                </button>
            </form>

            <div class="register-link">
                <a asp-action="Login" asp-area="Owner" asp-controller="Auth">Уже есть аккаунт? Войти</a>
            </div>

        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
