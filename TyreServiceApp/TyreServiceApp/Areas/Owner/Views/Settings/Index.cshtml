@model TyreServiceApp.Models.OwnerSetting

@{
    ViewData["Title"] = "Настройки";
}

<div class="main-3d-wrapper" style="max-width:500px;margin:0 auto;">
    <div class="main-3d-inner">
        <h4 class="fw-bold mb-4"><i class="bi bi-gear me-2"></i>Настройки владельца</h4>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success py-2">@TempData["Success"]</div>
        }

        <form asp-action="Index">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="AcquiringFeePercent" class="form-label fw-semibold">Эквайринг (%)</label>
                <input asp-for="AcquiringFeePercent" class="form-control" type="number" step="0.01" min="0" max="100" />
                <span asp-validation-for="AcquiringFeePercent" class="text-danger small"></span>
                <div class="form-text">Процент, который банк удерживает за приём платежей (по умолчанию 2%)</div>
            </div>

            <div class="mb-3">
                <label asp-for="TaxPercent" class="form-label fw-semibold">Налоги (%)</label>
                <input asp-for="TaxPercent" class="form-control" type="number" step="0.01" min="0" max="100" />
                <span asp-validation-for="TaxPercent" class="text-danger small"></span>
                <div class="form-text">Процент налогов (по умолчанию 6%)</div>
            </div>

            <button type="submit" class="btn btn-dark w-100">Сохранить</button>
        </form>
    </div>
</div>

<style>
    .main-3d-wrapper {
        position: relative;
        background: #000;
        border-radius: 0.75em;
    }
    .main-3d-inner {
        background: #fff;
        border: 2px solid #000;
        border-radius: 0.75em;
        padding: 30px;
        transform: translateY(-0.15em);
    }
</style>
