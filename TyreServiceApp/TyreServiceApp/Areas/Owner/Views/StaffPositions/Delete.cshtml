@model TyreServiceApp.Models.StaffPosition

@{
    ViewData["Title"] = "Удалить должность персонала";
}

<partial name="_FormStyles" />

<div class="container-fluid pt-2 pb-4">
    <div class="main-3d-wrapper" style="--mw: 600px">
        <div class="main-3d-inner">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h3 class="fw-bold m-0">
                    Удалить должность персонала
                </h3>
            </div>

            <div class="alert alert-danger d-flex align-items-center gap-2">
                <i class="bi bi-exclamation-triangle-fill"></i>
                <span>Вы уверены, что хотите удалить эту должность?</span>
            </div>

            <dl class="row">
                <dt class="col-sm-4">Название</dt>
                <dd class="col-sm-8">@Model.Name</dd>
            </dl>

            <form asp-action="Delete">
                <input type="hidden" asp-for="StaffPositionId" />
                <div class="d-flex gap-2 mt-4 pt-2">
                    <button type="submit" class="btn btn-danger px-4">
                        <i class="bi bi-trash"></i> Удалить
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary px-4">
                        <i class="bi bi-x-lg"></i> Отмена
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>
