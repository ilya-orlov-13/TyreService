@model TyreServiceApp.Models.AdminUser

@{
    ViewData["Title"] = "Удалить администратора";
}

<partial name="_FormStyles" />
<style>
    .modern-btn-danger {
        background-color: #dc3545;
        color: white;
    }

    .modern-btn-danger:hover {
        background-color: #bb2d3b;
        color: white;
        text-decoration: none;
    }

    .details-row {
        display: flex;
        padding: 12px 0;
        border-bottom: 1px solid #e9ecef;
    }

    .details-row:last-child {
        border-bottom: none;
    }

    .details-label {
        width: 140px;
        font-weight: 600;
        color: #495057;
        flex-shrink: 0;
    }

    .details-value {
        flex: 1;
        color: #212529;
    }

    .warning-icon {
        font-size: 3rem;
        color: #dc3545;
    }
</style>

<div class="container-fluid pt-2 pb-4">
    <div class="main-3d-wrapper" style="--mw: 600px; --button_outline_color: #dc2626">
        <div class="main-3d-inner">
            <div class="text-center mb-4">
                <i class="bi bi-exclamation-triangle-fill warning-icon"></i>
                <h3 class="fw-bold mt-2">Удалить администратора</h3>
                <p class="text-muted">Вы уверены, что хотите удалить этого администратора?</p>
            </div>

            @if (ViewData.ModelState.ErrorCount > 0)
            {
                <div class="alert alert-danger">
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <div>@error.ErrorMessage</div>
                    }
                </div>
            }

            <div class="border rounded p-3 mb-4 bg-light">
                <div class="details-row">
                    <div class="details-label">
                        <i class="bi bi-person me-1"></i> Логин:
                    </div>
                    <div class="details-value fw-bold">
                        @Html.DisplayFor(model => model.Login)
                    </div>
                </div>
                <div class="details-row">
                    <div class="details-label">
                        <i class="bi bi-person-badge me-1"></i> Имя:
                    </div>
                    <div class="details-value">
                        @(string.IsNullOrEmpty(Model.FullName) ? "—" : Model.FullName)
                    </div>
                </div>
                <div class="details-row">
                    <div class="details-label">
                        <i class="bi bi-envelope me-1"></i> Email:
                    </div>
                    <div class="details-value">
                        @(string.IsNullOrEmpty(Model.Email) ? "—" : Model.Email)
                    </div>
                </div>
            </div>

            <form asp-action="Delete" class="d-flex gap-2 justify-content-center">
                <input type="hidden" asp-for="AdminUserId" />
                <button type="submit" class="modern-btn modern-btn-danger">
                    <i class="bi bi-trash"></i> Удалить
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary px-4">
                    <i class="bi bi-arrow-left"></i> Назад
                </a>
            </form>
        </div>
    </div>
</div>
